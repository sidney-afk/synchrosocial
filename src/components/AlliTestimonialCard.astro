---
import { alliTestimonial as testimonial } from "../data/alliTestimonial.js";

interface Props {
  class?: string;
  articleClass?: string;
  videoClass?: string;
}

const {
  class: className = "",
  articleClass = "",
  videoClass = "w-[250px] max-md:w-full",
} = Astro.props;
---

<div class={`alli-testimonial flex w-full flex-col gap-[30px] ${className}`}>
  <div class="w-full overflow-hidden">
    <div class="flex w-max gap-5 max-md:overflow-x-auto max-md:pb-1">
      <div class="testimonial-tab flex min-h-20 w-[320px] shrink-0 flex-col justify-center gap-0.5 rounded-xl border border-[#262626] bg-[#26262666] px-4 pr-6 max-md:w-[270px]">
        <p class="text-base font-medium leading-6 text-white">{testimonial.name}</p>
        <p class="text-sm leading-5 text-[#c4c4c4]">{testimonial.role}</p>
      </div>
    </div>
  </div>

  <article class={`min-h-[620px] w-full rounded-[50px] border border-[#262626] bg-[#141414] px-10 py-10 max-lg:min-h-[560px] max-md:min-h-0 max-md:rounded-[32px] max-md:px-6 max-md:py-6 ${articleClass}`}>
    <div class="flex items-start gap-10 max-md:flex-col max-md:gap-6">
      <div class={`relative aspect-[9/16] shrink-0 overflow-hidden rounded-[5px] bg-black ${videoClass}`}>
        <iframe
          src={`https://fast.wistia.net/embed/iframe/${testimonial.wistia}?seo=false&videoFoam=false`}
          class="absolute inset-0 h-full w-full"
          title={`${testimonial.name} testimonial`}
          allow="autoplay; fullscreen"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>

      <div class="flex max-w-[655px] flex-col gap-6 pt-1 max-md:max-w-none max-md:pt-0">
        <h3 class="text-2xl font-medium leading-[133%] text-white max-md:text-xl">
          {testimonial.title}
        </h3>
        <p class="text-base leading-[157%] text-[#c4c4c4]">
          {testimonial.body}
        </p>
      </div>
    </div>
  </article>
</div>
