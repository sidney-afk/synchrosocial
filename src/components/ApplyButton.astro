---
// Primary CTA, matched to the reference geometry: flat brand fill with a
// subtle sheen (.btn-g), 12px radius, 20px/36px padding, 20px/600 label,
// and a 48px white rounded-square arrow chip inset 8px from the right.
// `md` is the navbar size (12px/28px padding, 16px label, no arrow chip).
interface Props {
  href?: string;
  label?: string;
  size?: "md" | "lg";
  arrow?: boolean;
  /** "down" renders a double-chevron (e.g. "Apply Below" scroll buttons). */
  arrowDir?: "right" | "down";
  class?: string;
}
const {
  href = "/apply",
  label = "Apply Now",
  size = "lg",
  arrow = true,
  arrowDir = "right",
  class: className = "",
} = Astro.props;

const pad = size === "lg" ? "px-9 py-5" : "px-7 py-3";
const text = size === "lg" ? "text-xl leading-none" : "text-base leading-[150%]";
---

<a
  href={href}
  class={`btn-g relative flex items-center justify-center gap-2 overflow-hidden rounded-xl font-semibold capitalize text-white ${pad} ${className}`}
>
  <span class={`${text} whitespace-nowrap`}>{label}</span>
  {
    arrow && (
      <span
        class="absolute right-2 top-1/2 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-lg bg-white"
        aria-hidden="true"
      >
        {
          arrowDir === "down" ? (
            <svg
              viewBox="0 0 48 48"
              class="h-12 w-12"
              fill="none"
              stroke="var(--g-purple)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M17 16.5l7 7 7-7" />
              <path d="M17 25.5l7 7 7-7" />
            </svg>
          ) : (
            <svg
              viewBox="0 0 48 48"
              class="h-12 w-12"
              fill="none"
              stroke="var(--g-purple)"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M26.43 17.93 32.5 24l-6.07 6.07" />
              <path d="M15.5 24h16.86" />
            </svg>
          )
        }
      </span>
    )
  }
</a>
<script is:inline>
  /* Preserve Meta/iClosed test mode when testing the full homepage -> apply
     path. Normal visitors never have this query param, so production links are
     unchanged. */
  (function () {
    var params = new URLSearchParams(window.location.search);
    if (params.get("test-pixel") !== "true") return;
    var link = document.currentScript && document.currentScript.previousElementSibling;
    if (!link || link.tagName !== "A") return;
    var href = link.getAttribute("href") || "";
    if (!href.startsWith("/apply")) return;
    try {
      var url = new URL(href, window.location.origin);
      url.searchParams.set("test-pixel", "true");
      link.setAttribute("href", url.pathname + url.search + url.hash);
    } catch (err) {}
  })();
</script>
