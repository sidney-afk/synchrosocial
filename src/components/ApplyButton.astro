---
// Primary CTA, matched to the reference geometry: flat brand fill with a
// subtle sheen (.btn-g), 12px radius, 20px/36px padding, 20px/600 label,
// and a 48px white rounded-square arrow chip inset 8px from the right.
// `md` is the navbar size (12px/28px padding, 16px label, no arrow chip).
interface Props {
  href?: string;
  label?: string;
  size?: "md" | "lg";
  arrow?: boolean;
  class?: string;
}
const {
  href = "/apply",
  label = "Apply Now",
  size = "lg",
  arrow = true,
  class: className = "",
} = Astro.props;

const pad = size === "lg" ? "px-9 py-5" : "px-7 py-3";
const text = size === "lg" ? "text-xl leading-none" : "text-base leading-[150%]";
---

<a
  href={href}
  class={`btn-g relative flex items-center justify-center gap-2 overflow-hidden rounded-xl font-semibold capitalize text-white ${pad} ${className}`}
>
  <span class={text}>{label}</span>
  {
    arrow && (
      <span
        class="absolute right-2 top-1/2 flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-lg bg-white"
        aria-hidden="true"
      >
        <svg
          viewBox="0 0 48 48"
          class="h-12 w-12"
          fill="none"
          stroke="var(--g-purple)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M26.43 17.93 32.5 24l-6.07 6.07" />
          <path d="M15.5 24h16.86" />
        </svg>
      </span>
    )
  }
</a>
