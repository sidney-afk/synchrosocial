---
const imageBase = "/images/audience-skyrocket/";

const comparisonCards = [
  {
    label: "Before",
    src: "baya-before.png",
    alt: "Baya Voce Instagram account before growth",
    variant: "crop",
    position: "center",
  },
  {
    label: "After",
    src: "baya-after.png",
    alt: "Baya Voce Instagram account after growth",
    variant: "crop",
    position: "center",
  },
  {
    label: "Before",
    src: "lucas-before.png",
    alt: "Lucas Salame Instagram account before growth",
    variant: "short",
    position: "center",
  },
  {
    label: "After",
    src: "lucas-after.png",
    alt: "Lucas Salame Instagram account after growth",
    variant: "short",
    position: "center",
  },
  {
    label: "Before",
    src: "danny-before-feed.png",
    alt: "Danny Morel Instagram account before growth",
    variant: "phone",
    position: "top",
  },
  {
    label: "After",
    src: "danny-after-feed.png",
    alt: "Danny Morel Instagram account after growth",
    variant: "phone",
    position: "top",
  },
];

const proofTiles = [
  {
    src: "baya-instagram-growth.png",
    alt: "Baya Voce before and after Instagram follower growth proof",
    title: "6.8K to 356K followers",
    shape: "wide",
  },
  {
    src: "danny-morel-2025-growth.png",
    alt: "Danny Morel thirty day Instagram growth analytics",
    title: "+47,640 followers in 30 days",
    shape: "phone",
  },
  {
    src: "insights-overview.png",
    alt: "Instagram insights overview showing reach growth",
    title: "3.9M accounts reached",
    shape: "phone",
  },
  {
    src: "danny-morel-tiktok.jpg",
    alt: "Danny Morel TikTok profile at one million followers",
    title: "1M TikTok followers",
    shape: "wide",
  },
  {
    src: "danny-morel-podcast-millions.png",
    alt: "Podcast clips with millions of views",
    title: "Millions of podcast views",
    shape: "wide",
  },
  {
    src: "amber-rae-bestseller.png",
    alt: "USA Today bestselling booklist proof for Amber Rae",
    title: "USA Today bestseller support",
    shape: "square",
  },
  {
    src: "danny-podcast-chart.png",
    alt: "Apple Podcasts chart showing Danny Morel at number one",
    title: "#1 Apple Podcasts spirituality",
    shape: "wide",
  },
  {
    src: "jessica-growth-chart.png",
    alt: "Jessica Winterstern follower growth chart",
    title: "Long-term follower growth",
    shape: "wide",
  },
  {
    src: "oliver-nino-before-after.png",
    alt: "Oliver Nino before and after follower growth proof",
    title: "600,000 new followers",
    shape: "wide",
  },
  {
    src: "youtube-100k-plaque.png",
    alt: "YouTube 100K subscriber plaque",
    title: "100K YouTube subscribers",
    shape: "square",
  },
  {
    src: "jessica-client-message.png",
    alt: "Client message praising new content",
    title: "Client loved the new content",
    shape: "message",
  },
  {
    src: "sabrina-client-message.png",
    alt: "Client message praising edits and music",
    title: "Edits praised by client",
    shape: "message",
  },
  {
    src: "amber-reel-comment.png",
    alt: "Client comment about one million views on the first reel",
    title: "1M views on the first reel",
    shape: "message",
  },
];

const proofColumns = [
  [proofTiles[0], proofTiles[1], proofTiles[4], proofTiles[10]],
  [proofTiles[2], proofTiles[3], proofTiles[5], proofTiles[11]],
  [proofTiles[9], proofTiles[6], proofTiles[7], proofTiles[8], proofTiles[12]],
];
---

<section class="audience-skyrocket" aria-labelledby="audience-skyrocket-title">
  <div class="audience-skyrocket__panel">
    <h2 id="audience-skyrocket-title" class="audience-skyrocket__title">
      Watch Your<br />
      Audience <em>Skyrocket</em> <span aria-hidden="true">🚀</span>
    </h2>

    <div class="audience-skyrocket__comparison" aria-label="Before and after client growth screenshots">
      {
        comparisonCards.map((card) => (
          <figure class={`skyrocket-card ${card.variant.split(" ").map((item) => `skyrocket-card--${item}`).join(" ")}`}>
            <div class={`skyrocket-card__bar skyrocket-card__bar--${card.label.toLowerCase()}`}>
              {card.label}
            </div>
            <div class="skyrocket-card__media">
              <img
                src={`${imageBase}${card.src}`}
                alt={card.alt}
                loading="eager"
                fetchpriority="low"
                decoding="async"
                style={`object-position: ${card.position};`}
              />
            </div>
          </figure>
        ))
      }
    </div>

    <div class="audience-skyrocket__proof-heading">
      <div class="audience-skyrocket__proof-rule" aria-hidden="true"></div>
      <p class="audience-skyrocket__eyebrow">More proof behind the growth</p>
      <h3>Metrics, media wins, and client receipts</h3>
      <p class="audience-skyrocket__proof-copy">
        Reach spikes, follower jumps, platform rankings, subscriber milestones,
        and direct client feedback from the same growth engine.
      </p>
    </div>

    <div class="audience-skyrocket__proof" aria-label="Additional client proof screenshots">
      {
        proofColumns.map((column) => (
          <div class="audience-skyrocket__proof-column">
            {column.map((tile) => (
              <figure class={`proof-tile proof-tile--${tile.shape}`}>
                <div class="proof-tile__media">
                  <img
                    src={`${imageBase}${tile.src}`}
                    alt={tile.alt}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <figcaption>{tile.title}</figcaption>
              </figure>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .audience-skyrocket {
    width: 100%;
    padding: 160px 0;
    background: #010b13;
    color: #fff;
  }

  .audience-skyrocket__panel {
    width: min(1040px, 95%);
    margin: 0 auto;
    padding: 48px 0 96px;
    border: 1px solid rgba(40, 129, 255, 0.18);
    border-radius: 20px;
    background: #010f23;
  }

  .audience-skyrocket__title {
    width: min(560px, 92%);
    margin: 0 auto 56px;
    color: #fff;
    font-family: "Inter Tight", Arial, sans-serif;
    font-size: 48px;
    font-weight: 700;
    line-height: 48px;
    letter-spacing: 0;
    text-align: center;
  }

  .audience-skyrocket__title em {
    color: #d39e29;
    font-style: italic;
  }

  .audience-skyrocket__comparison {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 420px));
    justify-content: center;
    gap: 16px;
    width: min(856px, calc(100% - 48px));
    margin: 0 auto;
  }

  .skyrocket-card {
    overflow: hidden;
    margin: 0;
    background: #fff;
  }

  .skyrocket-card__bar {
    display: flex;
    height: 40px;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-family: "Inter", Arial, sans-serif;
    font-size: 14px;
    font-style: italic;
    font-weight: 700;
    line-height: 20px;
    text-transform: uppercase;
  }

  .skyrocket-card__bar--before {
    background: linear-gradient(180deg, #ff0808 0%, #b20c0c 100%);
  }

  .skyrocket-card__bar--after {
    background: linear-gradient(180deg, #26ff00 0%, #19a800 100%);
  }

  .skyrocket-card__media {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #fff;
  }

  .skyrocket-card__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .skyrocket-card--crop .skyrocket-card__media {
    aspect-ratio: 420 / 292;
  }

  .skyrocket-card--crop .skyrocket-card__media img {
    object-fit: cover;
  }

  .skyrocket-card--short .skyrocket-card__media {
    height: 292px;
    background: #0b0f17;
  }

  .skyrocket-card--phone .skyrocket-card__media {
    height: 490px;
    background: #05070b;
  }

  .audience-skyrocket__proof-heading {
    width: min(856px, calc(100% - 48px));
    margin: 72px auto 0;
    text-align: center;
  }

  .audience-skyrocket__proof-rule {
    width: 100%;
    height: 1px;
    margin-bottom: 32px;
    background: linear-gradient(
      90deg,
      rgba(131, 49, 232, 0),
      rgba(131, 49, 232, 0.85),
      rgba(211, 158, 41, 0.65),
      rgba(131, 49, 232, 0)
    );
  }

  .audience-skyrocket__eyebrow {
    margin: 0 0 10px;
    color: #d39e29;
    font-family: "Inter", Arial, sans-serif;
    font-size: 13px;
    font-weight: 700;
    line-height: 18px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .audience-skyrocket__proof-heading h3 {
    margin: 0;
    color: #fff;
    font-family: "Inter Tight", Arial, sans-serif;
    font-size: 32px;
    font-weight: 700;
    line-height: 36px;
    letter-spacing: 0;
  }

  .audience-skyrocket__proof-copy {
    width: min(620px, 100%);
    margin: 12px auto 0;
    color: #c4c4c4;
    font-family: "Inter", Arial, sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 25px;
  }

  .audience-skyrocket__proof {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    width: min(856px, calc(100% - 48px));
    margin: 32px auto 0;
  }

  .audience-skyrocket__proof-column {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 16px;
  }

  .proof-tile {
    display: flex;
    min-width: 0;
    width: 100%;
    flex-direction: column;
    gap: 12px;
    margin: 0;
    padding: 12px;
    border: 1px solid rgba(131, 49, 232, 0.55);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(131, 49, 232, 0.1), rgba(131, 49, 232, 0)),
      rgba(9, 4, 20, 0.72);
  }

  .proof-tile__media {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    min-height: 0;
    border-radius: 4px;
    background: #fff;
  }

  .proof-tile__media img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .proof-tile figcaption {
    color: #fff;
    font-family: "Inter", Arial, sans-serif;
    font-size: 16px;
    font-weight: 700;
    line-height: 20px;
  }

  @media (max-width: 900px) {
    .audience-skyrocket {
      padding: 80px 0;
    }

    .audience-skyrocket__panel {
      width: calc(100% - 32px);
      padding-bottom: 64px;
    }

    .audience-skyrocket__comparison,
    .audience-skyrocket__proof-heading,
    .audience-skyrocket__proof {
      width: calc(100% - 48px);
    }

    .audience-skyrocket__proof {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .audience-skyrocket {
      padding: 60px 0;
    }

    .audience-skyrocket__panel {
      width: 100%;
      padding: 48px 16px 56px;
    }

    .audience-skyrocket__title {
      width: 100%;
      margin-bottom: 36px;
      font-size: 36px;
      line-height: 38px;
    }

    .audience-skyrocket__comparison {
      width: 100%;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .audience-skyrocket__proof-heading {
      width: 100%;
      margin-top: 44px;
    }

    .audience-skyrocket__proof-rule {
      margin-bottom: 24px;
    }

    .audience-skyrocket__eyebrow {
      font-size: 11px;
      line-height: 16px;
    }

    .audience-skyrocket__proof-heading h3 {
      font-size: 24px;
      line-height: 28px;
    }

    .audience-skyrocket__proof-copy {
      font-size: 14px;
      line-height: 21px;
    }

    .skyrocket-card__bar {
      height: 30px;
      font-size: 11px;
      line-height: 14px;
    }

    .skyrocket-card--short .skyrocket-card__media,
    .skyrocket-card--phone .skyrocket-card__media {
      height: 270px;
    }

    .audience-skyrocket__proof {
      width: 100%;
      grid-template-columns: 1fr;
      margin-top: 24px;
    }
  }
</style>
