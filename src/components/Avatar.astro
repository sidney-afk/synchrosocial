---
// Circular avatar. If `src` is given it shows the real photo on top of an
// initials-on-gradient base; if the image is missing/fails to load, it falls
// back to the initials automatically (never a broken image).
// Drop real images into /public/images and pass `src="/images/<file>"`.
interface Props {
  name: string;
  src?: string | null;
  size?: number; // px
  class?: string;
}
const { name, src = null, size = 72, class: className = "" } = Astro.props;

const initials = name
  .split(/\s+/)
  .slice(0, 2)
  .map((w) => w[0]?.toUpperCase() ?? "")
  .join("");

// Deterministic gradient per name so the placeholders feel intentional.
const gradients = [
  "from-brand-400 to-brand-600",
  "from-coral-400 to-coral-600",
  "from-violet-400 to-fuchsia-600",
  "from-indigo-400 to-brand-500",
  "from-rose-400 to-coral-500",
  "from-purple-400 to-indigo-500",
];
let hash = 0;
for (let i = 0; i < name.length; i++) hash = (hash * 31 + name.charCodeAt(i)) >>> 0;
const gradient = gradients[hash % gradients.length];
const dims = `width:${size}px;height:${size}px;`;
---

<div class={`relative shrink-0 ${className}`} style={dims}>
  <div
    class={`flex h-full w-full items-center justify-center rounded-full bg-gradient-to-br ${gradient} font-bold text-white ring-2 ring-white/70`}
    style={`font-size:${Math.round(size * 0.36)}px;`}
    aria-label={name}
  >
    {initials}
  </div>
  {
    src && (
      <img
        src={src}
        alt={name}
        loading="lazy"
        class="absolute inset-0 h-full w-full rounded-full object-cover ring-2 ring-white/70"
        onerror="this.style.display='none'"
      />
    )
  }
</div>
