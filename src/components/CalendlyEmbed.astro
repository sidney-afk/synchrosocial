---
// Inline Calendly scheduler. Pass the Calendly slug, e.g. "kasper-synchro/demo".
interface Props {
  slug: string;
  height?: string;
  class?: string;
}
const { slug, height = "700px", class: className = "" } = Astro.props;
const url = `https://calendly.com/${slug}`;
---

<div class={`overflow-hidden rounded-2xl bg-white shadow-xl ring-1 ring-black/5 ${className}`}>
  <div
    class="calendly-inline-widget"
    data-url={url}
    style={`min-width:320px;height:${height};`}
  >
  </div>
</div>

<script
  is:inline
  type="text/javascript"
  src="https://assets.calendly.com/assets/external/widget.js"
  async></script>
