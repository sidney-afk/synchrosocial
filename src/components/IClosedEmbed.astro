---
// iClosed booking widget (official inline embed).
//
// Renders iClosed's auto-resizing inline scheduler. Pass a full booking `url`
// or a `linkPrefix` like "synchrosocial/social-media-consultation"; iClosed's widget.js turns
// the .iclosed-widget div into the live scheduler iframe and keeps its height
// in sync with the content (data-resize). Booking an event writes it to the
// host's connected Google Calendar (Kasper's, on the live account).
//
//   <IClosedEmbed linkPrefix="synchrosocial/social-media-consultation" />
//   <IClosedEmbed url="https://app.iclosed.io/e/synchrosocial/social-media-consultation" />
interface Props {
  url?: string | null;
  linkPrefix?: string | null;
  height?: string;
  title?: string;
  class?: string;
  card?: boolean;
}
const {
  url = null,
  linkPrefix = null,
  height = "760px",
  title = "Book a call",
  class: className = "",
  card = true,
} = Astro.props;

// iClosed's inline widget is transparent and renders its OWN white card (with
// an 8px radius + subtle border) around the scheduler content, which is fixed
// at ~811px wide and centered inside the iframe — it does not grow with the
// iframe. When we wrap it in our own opaque `bg-white` card that is wider than
// 811px (needed so iClosed's container query lays the form + calendar side by
// side at >= 900px), our card's background shows as empty bands on the left and
// right of the content. Passing `card={false}` drops our wrapper so only
// iClosed's own card shows on the page background — matching the Growth Topia
// reference, which embeds the bare transparent iframe with no wrapper at all.
const cardClass = "overflow-hidden rounded-2xl bg-white shadow-2xl ring-1 ring-black/5";
const wrapperClass = [
  "iclosed-embed",
  card ? cardClass : "",
  className,
].filter(Boolean).join(" ");

const bookingUrl =
  url ?? (linkPrefix ? `https://app.iclosed.io/e/${linkPrefix}` : null);

// Static day grid — purely decorative for the placeholder.
const days = Array.from({ length: 30 }, (_, i) => i + 1);
const weekdays = ["SUN", "MON", "TUE", "WED", "THU", "FRI", "SAT"];
const monthLabel = new Date().toLocaleDateString("en-US", {
  month: "long",
  year: "numeric",
});
---

{
  bookingUrl ? (
    <div
      class={wrapperClass}
      data-iclosed-embed
      data-ready="false"
      style={`--iclosed-embed-height:${height};`}
    >
      <div
        class="iclosed-widget"
        data-url={bookingUrl}
        data-resize="true"
        title={title}
        style={`width:100%;min-width:320px;height:${height};`}
      />
      <div class="iclosed-embed__loader" aria-hidden="true">
        <div class="iclosed-embed__loader-card">
          <div class="iclosed-embed__loader-header">
            <span class="iclosed-embed__skeleton iclosed-embed__skeleton--header" />
            <span class="iclosed-embed__skeleton iclosed-embed__skeleton--header" />
          </div>
          <div class="iclosed-embed__loader-body">
            <span class="iclosed-embed__skeleton iclosed-embed__skeleton--title" />
            <span class="iclosed-embed__skeleton iclosed-embed__skeleton--label" />
            <span class="iclosed-embed__skeleton iclosed-embed__skeleton--field" />
            <span class="iclosed-embed__skeleton iclosed-embed__skeleton--label" />
            <span class="iclosed-embed__skeleton iclosed-embed__skeleton--field" />
            <span class="iclosed-embed__skeleton iclosed-embed__skeleton--button" />
          </div>
        </div>
      </div>
      <script
        is:inline
        type="text/javascript"
        src="https://app.iclosed.io/assets/widget.js"
        async
      />
      <script is:inline>
        /* iClosed → Meta Pixel bridge.
           The booking iframe posts lifecycle events to this page (documented
           in iClosed's GTM guide): iclosed.potential / .qualified /
           .disqualified / .call_scheduled. Firing the pixel here catches the
           booking the moment it happens — including calendars that use
           iClosed-internal confirmation and never redirect (e.g. /call).
           The event ID is stored so /thank-you can re-fire the same booking
           with the SAME ID and Meta deduplicates (event name + ID, 48h).
           See docs/meta-ads/README.md for the full event map. */
        if (!window.__iclosedMetaBridge) {
          window.__iclosedMetaBridge = true;
          window.addEventListener("message", function (e) {
            if (e.origin !== "https://app.iclosed.io") return;
            var t = e.data && e.data.type;
            if (!t || typeof window.fbq !== "function") return;
            if (t === "iclosed.potential") fbq("trackCustom", "iclosed_potential");
            if (t === "iclosed.qualified") fbq("trackCustom", "iclosed_qualified");
            if (t === "iclosed.disqualified") fbq("trackCustom", "iclosed_disqualified");
            if (t === "iclosed.call_scheduled") {
              var eid =
                window.crypto && crypto.randomUUID
                  ? crypto.randomUUID()
                  : String(Date.now()) + "-" + Math.random().toString(36).slice(2);
              try {
                sessionStorage.setItem(
                  "ss_booked_eid",
                  JSON.stringify({ eid: eid, at: Date.now() })
                );
              } catch (err) {}
              /* Schedule + Lead mark the same moment; pick ONE as the
                 campaign's optimization event in Ads Manager. */
              fbq("track", "Schedule", {}, { eventID: eid });
              fbq("track", "Lead", {}, { eventID: "lead-" + eid });
            }
          });
        }
      </script>
      <script is:inline>
        /* Show a stable loader while iClosed injects and resizes its iframe.
           Then swap to the real scheduler once the initial height burst is
           quiet, preserving iClosed's final card exactly. */
        (function () {
          if (window.__ssIClosedStabilizer) {
            window.__ssIClosedStabilizer.init();
            return;
          }

          var ICLOSED_ORIGINS = {
            "https://dev.iclosed.io": true,
            "https://stage.iclosed.io": true,
            "https://app.iclosed.io": true,
          };

          function stabilize(root) {
            if (!root || root.__ssIClosedReadySetup) return;
            root.__ssIClosedReadySetup = true;

            var readyTimer = null;
            var fallbackTimer = null;
            var iframeSeenAt = 0;
            var iframeLoaded = false;
            var heightMessageCount = 0;
            var lastHeightMessageAt = 0;

            function iframe() {
              return root.querySelector("iframe");
            }

            function show() {
              if (!iframe()) return;
              root.setAttribute("data-ready", "true");
              if (readyTimer) clearTimeout(readyTimer);
              if (fallbackTimer) clearTimeout(fallbackTimer);
            }

            function shouldShow() {
              var node = iframe();
              if (!node) return false;

              var now = Date.now();
              var iframeAge = iframeSeenAt ? now - iframeSeenAt : 0;
              var quietFor = lastHeightMessageAt ? now - lastHeightMessageAt : 0;

              if (heightMessageCount > 0 && quietFor >= 1400) return true;
              if (iframeLoaded && iframeAge >= 6500) return true;
              return iframeAge >= 9000;
            }

            function showAfterQuiet(delay) {
              if (root.getAttribute("data-ready") === "true") return;
              if (readyTimer) clearTimeout(readyTimer);
              readyTimer = setTimeout(function () {
                if (shouldShow()) show();
                else showAfterQuiet(250);
              }, delay);
            }

            root.__ssIClosedNoteHeight = function () {
              iframeSeenAt = iframeSeenAt || Date.now();
              heightMessageCount += 1;
              lastHeightMessageAt = Date.now();
              showAfterQuiet(1450);
            };

            function watchIframe(node) {
              if (!node || node.__ssIClosedLoadWatched) return;
              iframeSeenAt = iframeSeenAt || Date.now();
              node.__ssIClosedLoadWatched = true;
              node.addEventListener("load", function () {
                iframeLoaded = true;
                showAfterQuiet(1800);
              });
              showAfterQuiet(2600);
            }

            var observer = new MutationObserver(function () {
              watchIframe(iframe());
            });
            observer.observe(root, { childList: true, subtree: true });
            watchIframe(iframe());

            fallbackTimer = setTimeout(show, 9500);
          }

          function init() {
            document.querySelectorAll("[data-iclosed-embed]").forEach(stabilize);
          }

          window.addEventListener("message", function (event) {
            if (!ICLOSED_ORIGINS[event.origin]) return;
            if (!event.data || event.data.type !== "iclosed.widget_height") return;

            document.querySelectorAll("[data-iclosed-embed]").forEach(function (root) {
              var frame = root.querySelector("iframe");
              if (frame && frame.contentWindow === event.source) {
                stabilize(root);
                if (root.__ssIClosedNoteHeight) root.__ssIClosedNoteHeight();
              }
            });
          });

          if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", init);
          } else {
            init();
          }

          window.__ssIClosedStabilizer = { init: init };
        })();
      </script>
    </div>
  ) : (
    <div class={`overflow-hidden rounded-2xl bg-white shadow-2xl ring-1 ring-black/5 ${className}`}>
      {/* PLACEHOLDER — replace by passing your iClosed embed URL to `src`. */}
      <div class="border-b border-brand-100 bg-brand-50 px-5 py-2 text-center text-xs font-semibold text-brand-700">
        Placeholder — your iClosed booking widget will go here
      </div>

      <div class="flex items-center justify-center gap-6 border-b border-black/5 py-3 text-sm">
        <span class="flex items-center gap-2 font-medium text-brand-600">
          <span class="h-2 w-2 rounded-full bg-brand-500" />
          Fill out the form
        </span>
        <span class="flex items-center gap-2 text-muted/60">
          <span class="h-2 w-2 rounded-full bg-black/15" />
          Book your event
        </span>
      </div>

      <div class="grid gap-0 md:grid-cols-2">
        {/* Left: form */}
        <div class="border-b border-black/5 p-6 md:border-b-0 md:border-r">
          <h3 class="font-display text-lg font-bold text-ink">
            Social Media Consultation
          </h3>
          <p class="mt-1 text-sm text-muted">
            Fill in the info below and pick a time that works for you.
          </p>

          <div class="mt-5 space-y-3">
            <div class="flex h-11 items-center rounded-lg border border-black/10 px-3 text-sm text-muted/70">
              +1&nbsp; Phone number
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div class="flex h-11 items-center rounded-lg border border-black/10 px-3 text-sm text-muted/70">
                First name *
              </div>
              <div class="flex h-11 items-center rounded-lg border border-black/10 px-3 text-sm text-muted/70">
                Last name *
              </div>
            </div>
            <p class="text-xs leading-relaxed text-muted/70">
              By entering your information, you consent to your data being saved
              in accordance with our{" "}
              <a href="/terms-conditions" class="underline">Terms</a> &amp;{" "}
              <a href="/privacypolicy" class="underline">Privacy Policy</a>.
            </p>
            <div class="bg-brand-gradient flex h-11 items-center justify-center rounded-lg text-sm font-semibold text-white opacity-90">
              Continue ›
            </div>
          </div>
        </div>

        {/* Right: calendar */}
        <div class="p-6">
          <div class="flex items-center justify-between">
            <span class="font-semibold text-ink">{monthLabel}</span>
            <div class="flex gap-1 text-muted/50">
              <span class="flex h-7 w-7 items-center justify-center rounded-md border border-black/10">‹</span>
              <span class="flex h-7 w-7 items-center justify-center rounded-md border border-black/10">›</span>
            </div>
          </div>
          <div class="mt-4 grid grid-cols-7 gap-1 text-center text-[0.65rem] font-semibold text-muted/50">
            {weekdays.map((d) => (
              <span>{d}</span>
            ))}
          </div>
          <div class="mt-2 grid grid-cols-7 gap-1 text-center text-sm text-ink/70">
            {days.map((n) => (
              <span class="flex h-9 items-center justify-center rounded-md hover:bg-brand-50">
                {n}
              </span>
            ))}
          </div>
        </div>
      </div>

      <div class="border-t border-black/5 py-2 text-center text-xs text-muted/50">
        Powered by iClosed (placeholder)
      </div>
    </div>
  )
}

<style is:global>
  .iclosed-embed {
    position: relative;
  }

  .iclosed-embed[data-ready="false"] {
    min-height: var(--iclosed-embed-height, 620px);
  }

  .iclosed-embed__loader {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    pointer-events: none;
  }

  .iclosed-embed__loader-card {
    width: min(730px, 100%);
    height: min(392px, 100%);
    overflow: hidden;
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.08);
  }

  .iclosed-embed__loader-header {
    display: flex;
    height: 64px;
    align-items: center;
    justify-content: center;
    gap: 26px;
    border-bottom: 1px solid rgba(15, 23, 42, 0.1);
  }

  .iclosed-embed__loader-body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 24px 10% 26px;
  }

  .iclosed-embed__skeleton {
    display: block;
    border-radius: 999px;
    background:
      linear-gradient(
        90deg,
        #f3f4f7 0%,
        #eceef3 46%,
        #f7f8fa 58%,
        #f3f4f7 100%
      );
    background-size: 220% 100%;
    animation: iclosed-embed-shimmer 1.15s ease-in-out infinite;
  }

  .iclosed-embed__skeleton--header {
    width: 140px;
    height: 16px;
  }

  .iclosed-embed__skeleton--title {
    width: 160px;
    height: 20px;
    margin: 2px 0 36px;
  }

  .iclosed-embed__skeleton--label {
    width: 80px;
    height: 12px;
    margin-bottom: 10px;
  }

  .iclosed-embed__skeleton--field {
    width: min(240px, 72%);
    height: 24px;
    margin-bottom: 54px;
  }

  .iclosed-embed__skeleton--button {
    width: 100%;
    height: 42px;
    border-radius: 6px;
  }

  .iclosed-embed > .iclosed-widget {
    visibility: hidden;
    pointer-events: none;
  }

  .iclosed-embed[data-ready="false"] > .iclosed-widget {
    height: var(--iclosed-embed-height, 620px) !important;
    overflow: hidden;
  }

  .iclosed-embed[data-ready="true"] > .iclosed-widget {
    visibility: visible;
    pointer-events: auto;
  }

  .iclosed-embed[data-ready="true"] > .iclosed-embed__loader {
    display: none;
  }

  @keyframes iclosed-embed-shimmer {
    0% {
      background-position: 120% 0;
    }
    100% {
      background-position: -120% 0;
    }
  }

  @media (max-width: 560px) {
    .iclosed-embed__loader-card {
      height: min(390px, 100%);
    }

    .iclosed-embed__loader-header {
      height: 56px;
      gap: 16px;
    }

    .iclosed-embed__loader-body {
      padding: 22px 8% 24px;
    }

    .iclosed-embed__skeleton--header {
      width: 118px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .iclosed-embed__skeleton {
      animation: none;
    }
  }
</style>
