---
// Synchro Social logo — always the real logo.png lockup, on every page.
// `tone` is kept for backwards compatibility but no longer changes the mark.
interface Props {
  tone?: "brand" | "coral" | "white";
  href?: string | null;
  class?: string;
  imgClass?: string; // height of the PNG lockup
}
const {
  href = "/",
  class: className = "",
  imgClass = "h-16",
} = Astro.props;

const Tag = href ? "a" : "div";
---

<Tag
  {...href ? { href } : {}}
  class={`inline-block ${className}`}
  aria-label="Synchro Social"
>
  <img
    src="/images/logo.png"
    alt="Synchro Social"
    class={`${imgClass} w-auto`}
  />
</Tag>
