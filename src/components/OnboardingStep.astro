---
import Layout from "../layouts/Layout.astro";
import Logo from "./Logo.astro";
import Button from "./Button.astro";

// Shared shell for every onboarding step (main = dark/purple, AI = light/coral).
interface Props {
  theme: "dark" | "light";
  tone: "brand" | "coral";
  step: number; // 1..4
  title: string; // e.g. "What To Expect"
  next?: { href: string; label: string } | null;
  pageTitle?: string;
}
const { theme, tone, step, title, next = null, pageTitle } = Astro.props;

const isDark = theme === "dark";
const bodyClass = isDark
  ? "bg-[#0c0b10]"
  : "bg-gradient-to-b from-white via-coral-50 to-coral-100";
const logoTone = isDark ? "white" : "coral";
const eyebrowColor = isDark ? "text-brand-300" : "text-coral-500";
const headingColor = isDark ? "text-white" : "text-[#6f1d1d]";
const captionColor = isDark ? "text-white/50" : "text-coral-700/70";
---

<Layout
  title={pageTitle ?? `Step ${step}/4: ${title} — Synchro Social`}
  bodyClass={bodyClass}
>
  <main class="flex min-h-screen flex-col items-center px-6 py-12">
    <Logo tone={logoTone} href={null} />
    <p class={`mt-4 text-sm font-medium ${eyebrowColor}`}>Your Onboarding Below</p>

    <h1
      class={`font-display mt-2 text-center text-3xl font-extrabold sm:text-4xl md:text-5xl ${headingColor}`}
    >
      Step {step}/4: {title}
    </h1>

    <div class="mt-10 w-full max-w-3xl">
      <slot />
    </div>

    {
      next && (
        <div class="mt-10 flex flex-col items-center">
          <Button href={next.href} tone={tone} size="md">
            {next.label}
          </Button>
          <p class={`mt-3 text-[0.7rem] font-medium uppercase tracking-wider ${captionColor}`}>
            Click here to go to the next onboarding step
          </p>
        </div>
      )
    }
  </main>
</Layout>
