---
// Sticky dark top nav for the v2 homepage (mirrors the reference layout).
// Logo is rendered as a white horizontal lockup so it reads on the dark bar.
// `minimal` = logo only, centered (used on the focused /apply page).
interface Props {
  minimal?: boolean;
}
const { minimal = false } = Astro.props;

const links = [
  { label: "Home", href: "/v2" },
  { label: "Features", href: "/v2#features" },
  { label: "Case Studies", href: "/v2#results" },
  { label: "FAQ", href: "/v2#faq" },
];
---

<header class="sticky top-0 z-50 border-b border-white/5 bg-[#06040d]/90 backdrop-blur">
  <nav
    class={`mx-auto flex max-w-7xl items-center px-6 py-4 ${minimal ? "justify-center" : "justify-between"}`}
  >
    <a href="/v2" class="inline-flex items-center" aria-label="Synchro Social">
      <img src="/images/logo.png" alt="Synchro Social" class="h-12 w-auto" />
    </a>

    {
      !minimal && (
        <>
          <ul class="hidden items-center gap-8 text-sm font-medium text-white/80 md:flex">
            {links.map((l) => (
              <li>
                <a href={l.href} class="transition hover:text-white">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>

          <a
            href="/apply"
            class="inline-flex items-center rounded-xl bg-brand-gradient px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-brand-700/30 transition hover:brightness-110"
          >
            Apply Now
          </a>
        </>
      )
    }
  </nav>
</header>
