---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** Background color class for the page body wrapper. */
  bodyClass?: string;
}

const {
  title = "Synchro Social — Social media growth for coaches & thought leaders",
  description = "We help impact-driven coaches and thought leaders share their journey on social media. Grow exceptionally, but with intention.",
  bodyClass = "bg-white",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / social preview -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {Astro.site && <meta property="og:url" content={Astro.site} />}
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts: Poppins (classic pages) + Inter / Inter Tight / Caveat (v2 pages) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&family=Inter+Tight:wght@600;700&family=Outfit:wght@400;500;600;700&family=Poppins:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
