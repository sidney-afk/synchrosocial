---
import "../styles/global.css";
import MetaPixel from "../components/MetaPixel.astro";

interface Props {
  title?: string;
  description?: string;
  /** Background color class for the page body wrapper. */
  bodyClass?: string;
  /** Extra Meta Pixel event to fire on this page (besides PageView),
      e.g. { name: "Schedule" } on /thank-you. See docs/meta-ads/. */
  metaEvent?: { name: string; params?: Record<string, string | number> };
}

const {
  title = "Synchro Social — Social media growth for coaches & thought leaders",
  description = "We help impact-driven coaches and thought leaders share their journey on social media. Grow exceptionally, but with intention.",
  bodyClass = "bg-white",
  metaEvent = null,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="facebook-domain-verification" content="dblhsbm0xnlcnxb395nwdz9q4gvabc" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preload" href="/fonts/inter-tight-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/caveat-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="dns-prefetch" href="//app.iclosed.io" />
    <link rel="preconnect" href="https://app.iclosed.io" crossorigin />
    <link rel="preload" href="https://app.iclosed.io/assets/widget.js" as="script" />

    <!-- Open Graph / social preview -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {Astro.site && <meta property="og:url" content={Astro.site} />}
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Inter / Inter Tight / Caveat are self-hosted (see global.css @font-face,
         exact woff2 from the reference). Poppins + Outfit stay on Google Fonts
         for the classic / AI funnel pages. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Poppins:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600&display=swap"
      rel="stylesheet"
    />

    <MetaPixel event={metaEvent?.name} params={metaEvent?.params} />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
