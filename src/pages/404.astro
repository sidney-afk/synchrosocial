---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
import Button from "../components/Button.astro";
---

<Layout title="Page Not Found — Synchro Social">
  <main class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
    <Logo tone="brand" href="/" />
    <p class="font-display mt-10 text-7xl font-extrabold text-brand-600">404</p>
    <h1 class="mt-2 text-2xl font-bold text-ink">Page not found</h1>
    <p class="mt-3 max-w-md text-muted">
      The page you're looking for doesn't exist or has moved.
    </p>
    <div class="mt-8">
      <Button href="/" tone="brand">Back to Home</Button>
    </div>
  </main>
</Layout>
