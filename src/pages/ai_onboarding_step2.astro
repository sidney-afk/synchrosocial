---
import OnboardingStep from "../components/OnboardingStep.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import Button from "../components/Button.astro";

const formUrl = "https://form.jotform.com/260514381888061";
---

<OnboardingStep
  theme="light"
  tone="coral"
  step={2}
  title="Complete This Form"
  next={{ href: "/ai_onboarding_step3", label: "Take Me To The Next Step (3/4)" }}
>
  <VideoEmbed provider="placeholder" title="How to complete the form" tone="coral" />

  <div class="mt-8 flex flex-col items-center">
    <Button href={formUrl} tone="coral" size="md" target="_blank" rel="noopener">
      Fill In Form: General Onboarding Info
    </Button>
    <p class="mt-3 text-[0.7rem] font-medium uppercase tracking-wider text-coral-700/70">
      Fill this form before moving to the next step
    </p>
  </div>
</OnboardingStep>
