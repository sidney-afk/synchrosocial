---
import OnboardingStep from "../components/OnboardingStep.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import IClosedEmbed from "../components/IClosedEmbed.astro";
---

<OnboardingStep
  theme="light"
  tone="coral"
  step={3}
  title="Strategy Session"
  next={{ href: "/ai_onboarding_step4", label: "Take Me To The Next Step (4/4)" }}
>
  <VideoEmbed provider="wistia" id="19g7o47in3" title="Your strategy session" tone="coral" />

  <div class="mt-5">
    <p class="mb-4 text-center text-sm text-coral-700/80">
      Schedule your first strategy session with Synchro Social.
    </p>
    <IClosedEmbed linkPrefix="synchrosocial/ai-clone-consultation" />
  </div>
</OnboardingStep>
