---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import ApplyButton from "../components/ApplyButton.astro";

// STUB — placeholder Apply page.
// The real "Apply Now" flow is different from the homepage; it will be rebuilt
// once the screenshots are provided. For now this keeps every CTA working.
---

<Layout
  title="Apply — Synchro Social"
  description="Apply to work with Synchro Social."
  bodyClass="bg-[#07040f]"
>
  <SiteNav />

  <main class="bg-hero-purple">
    <div
      class="mx-auto flex min-h-[80vh] max-w-3xl flex-col items-center justify-center px-6 py-24 text-center text-white"
    >
      <p class="font-script text-2xl text-brand-200">Almost there</p>
      <h1 class="font-display mt-3 text-4xl font-extrabold sm:text-5xl">
        Application Page — Coming Soon
      </h1>
      <p class="mt-5 max-w-xl text-lg text-white/80">
        This is a placeholder. The real application flow will be built here next
        — send the screenshots whenever you're ready and I'll wire it up.
      </p>
      <div class="mt-10">
        <ApplyButton href="/v2" label="Back To Home" />
      </div>
    </div>
  </main>
</Layout>
