---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import IClosedLiftWidget from "../components/IClosedLiftWidget.astro";
import IClosedEmbed from "../components/IClosedEmbed.astro";
import CaseStudyVideo from "../components/CaseStudyVideo.astro";
import ApplyButton from "../components/ApplyButton.astro";
import PlatformIcon from "../components/PlatformIcon.astro";
import AudienceSkyrocket from "../components/AudienceSkyrocket.astro";
import AlliTestimonialCard from "../components/AlliTestimonialCard.astro";
import { caseStudies, slug } from "../data/caseStudies.js";

/* ===========================================================================
   APPLY PAGE — what happens when someone clicks "Apply Now".
   Matched 1:1 to the reference funnel's measured spec, in Synchro purple:
   100svh hero with bottom purple fade + half-highlight headline + booking,
   80px-padded case-study band, minimal rights-only footer.

   Booking uses Kasper's iClosed "Social Media Consultation" calendar
   (synchrosocial/social-media-consultation), which redirects to /thank-you. /call uses a
   sibling calendar (synchrosocial/ai-intro-call) — same questions, but an
   internal confirmation so the coral AI funnel doesn't jump to purple.
=========================================================================== */

// Case-study data + the name→slug helper are shared with /thank-you so the two
// pages never drift. Edit src/data/caseStudies.js to update both.

const ctaCaption = "Get Started In Less Than 60 Seconds • Cancel Anytime";
---

<Layout
  title="Apply — Synchro Social"
  description="Apply to work with Synchro Social. Grow your social media exceptionally, but with intention."
  bodyClass="v2"
  metaEvent={{ name: "ViewContent", params: { content_name: "apply" } }}
>
  <SiteNav minimal />
  <IClosedLiftWidget />

  <!-- ===================== HERO + BOOKING ===================== -->
  <section class="relative min-h-[100svh] pb-2 pt-20 max-lg:pb-2 max-lg:pt-10 max-md:pt-[18px]">
    <!-- Backdrop: transparent fading down to solid brand purple -->
    <div class="bg-hero-fade pointer-events-none absolute inset-0" aria-hidden="true"></div>

    <div class="relative z-[3] mx-auto flex w-full flex-col items-center gap-12 max-md:gap-8">
      <div class="flex w-full flex-col items-center gap-4 text-center max-md:gap-2">
        <p class="font-script text-2xl font-bold leading-5 text-[#b794ff] max-md:px-4 max-md:text-[17px] max-md:font-normal max-md:leading-[22px]">
          Impact-Driven Coaches, Thought Leaders &amp; Business Owners
        </p>
        <h1 class="font-tight text-[clamp(2.7rem,1.31rem+2.241vw,4rem)] font-bold capitalize leading-[1.2] text-white max-md:text-[22.5px] max-md:leading-[24.75px]">
          Hire The Team Behind{" "}
          <span class="inline-block whitespace-nowrap bg-[linear-gradient(0deg,var(--g-purple),var(--g-purple)_50%,transparent_50%)] px-4 max-md:px-1">Over 1 Billion Views</span>
          <br />
          Generated For Your Favorite Brands
        </h1>
        <div class="max-w-[686px] max-md:hidden">
          <p class="text-xl leading-[157%] max-md:text-lg">
            We'll install the content engine that makes you the go-to authority
            in your niche in 90 days.
          </p>
        </div>
      </div>

      <!-- Apply button — sits equidistant (gap-12) between the heading and the
           booking widget so the space above and below it matches. -->
      <div class="flex w-full max-w-[457px] flex-col max-md:w-[calc(100%-32px)] max-md:max-w-none">
        <ApplyButton href="#book" label="Apply Below" arrowDir="down" class="w-full" />
      </div>

      <!-- Booking — Kasper's iClosed "Social Media Consultation" calendar.
           Match Growthtopia/iClosed's official inline embed: a transparent
           full-width iframe host, no extra white wrapper, no custom loader gate. -->
      <div id="book" class="w-full min-h-[500px] scroll-mt-[128px] max-md:min-h-[560px] max-md:scroll-mt-[96px]">
        <div class="mx-auto w-full min-h-[500px] max-md:min-h-[560px] max-md:w-[calc(100%-32px)]">
          <IClosedEmbed
            linkPrefix="synchrosocial/social-media-consultation"
            title="Social Media Consultation"
            height="500px"
            card={false}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="w-full bg-black py-[60px] md:hidden">
    <div class="mx-auto flex w-[calc(100%-32px)] flex-col items-center gap-[30px]">
      <div class="flex w-full flex-col items-center gap-4 text-center">
        <h2 class="mx-auto max-w-[332px] font-tight text-[28px] font-bold capitalize leading-none text-white">
          Here's What Other Customers Are Saying
        </h2>
        <p class="max-w-[332px] text-base leading-[157%] text-[#c4c4c4]">
          We're happy to keep helping our customers to achieve their goals
        </p>
      </div>

      <AlliTestimonialCard articleClass="!min-h-0" videoClass="mx-auto w-full max-w-[306px]" />
    </div>
  </section>

  <!-- ===================== CASE STUDIES ===================== -->
  <section class="w-full bg-white pb-14 pt-6 text-black max-lg:pb-12 max-lg:pt-6">
    <div class="mx-auto flex w-[95%] max-w-[1040px] flex-col items-center gap-[60px] max-lg:gap-[30px]">
      <div class="flex w-full flex-col items-center gap-4 text-center">
        <h2 class="font-tight text-5xl font-bold capitalize leading-none text-black max-md:text-[28px]">
          <strong>Check Out (Just Some) Of Our Case Studies.</strong>
        </h2>
      </div>

      <div class="mt-0 flex w-full flex-col gap-12">
        {
          caseStudies.map((cs) => (
            <div class="flex w-full flex-col">
              <!-- Header -->
              <div class="mx-auto mb-4 flex w-full max-w-[61rem] flex-col items-center border-b border-black pb-4">
                <div class="text-lg font-light leading-[1.3]">SYNCHRO SOCIAL CASE STUDY</div>
                <h3 class="text-center text-[2.5rem] font-black uppercase leading-[1.3] max-md:text-[2rem]">
                  {cs.name}
                </h3>
                <div class="mt-8 self-start text-left text-2xl font-normal leading-[1.3] max-md:hidden">
                  RESULTS IN {cs.period.toUpperCase()}:
                </div>
              </div>

              <!-- Stats + photo + platforms -->
              <div class="mx-auto grid w-full max-w-[61rem] grid-cols-3 items-center gap-4 max-md:flex max-md:flex-col max-md:items-center max-md:gap-7 max-md:text-center">
                {cs.stats.map((s) => (
                  <div class="max-md:order-3 max-md:w-full">
                    <div class="text-[3.5rem] font-black leading-[1.3] max-lg:text-[3rem]">
                      {s.value}
                    </div>
                    <div class="text-xl font-normal leading-[1.3] max-md:text-base">{s.label}</div>
                  </div>
                ))}
                <div class="relative overflow-hidden rounded-[5px] max-md:order-1 max-md:mx-auto max-md:w-full max-md:max-w-[312px]">
                  <div class="flex aspect-square w-full items-center justify-center bg-gradient-to-br from-brand-300 to-brand-600 text-4xl font-bold text-white/90">
                    {cs.name.split(" ").map((w) => w[0]).join("")}
                  </div>
                  <img
                    src={`/images/clients/${slug(cs.name)}.jpg`}
                    alt={cs.name}
                    class="absolute inset-0 h-full w-full object-cover"
                    onerror="this.style.display='none'"
                  />
                </div>
                <div class="hidden max-md:order-2 max-md:block max-md:w-full max-md:border-b max-md:border-black max-md:pb-6 max-md:text-center max-md:text-[18px] max-md:font-normal max-md:leading-[23.4px]">
                  RESULTS IN {cs.period.toUpperCase()}:
                </div>
                <div class="col-span-3 flex items-center gap-4 text-2xl max-md:order-4 max-md:col-span-1 max-md:mt-4 max-md:flex-col max-md:justify-center">
                  <span>Platforms:</span>
                  <div class="flex gap-2">
                    {cs.platforms.map((p) => (
                      <PlatformIcon name={p} class="h-8 w-8" />
                    ))}
                  </div>
                </div>
              </div>

              <!-- Video examples -->
              <div class="mx-auto mt-8 flex w-full max-w-[61rem] flex-col gap-4">
                <div class="text-[2rem] font-black leading-[1.3] max-md:text-center max-md:text-2xl">Video examples:</div>
                <div class="grid w-full grid-cols-3 gap-16 max-lg:gap-8 max-md:grid-cols-1 max-md:gap-8">
                  {cs.videos.map((v) => (
                    <div class="flex w-full flex-col items-center justify-center gap-1">
                      <CaseStudyVideo
                        wistia={v.wistia}
                        poster={v.poster}
                        mp4={v.mp4}
                        mp4Poster={v.mp4Poster}
                        title={`${cs.name} reel — ${v.views} views`}
                      />
                      <div class="text-base font-bold leading-[1.3]">{v.views} views</div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-10 flex w-full max-w-[420px] flex-col items-center gap-4 text-center">
        <ApplyButton href="#book" label="Apply Now" class="w-full" />
        <p class="text-base leading-[157%] text-black">{ctaCaption}</p>
      </div>
    </div>
  </section>

  <AudienceSkyrocket ctaHref="#book" />

  <!-- ===================== FOOTER (minimal, rights only) ===================== -->
  <footer class="w-full px-0 py-8">
    <div class="mx-auto w-[95%] max-w-[1120px] border-t border-[#262626] pt-8">
      <p class="text-base leading-[150%] text-white">
        © {new Date().getFullYear()} Synchro Social LLC. All rights reserved.
      </p>
    </div>
  </footer>
</Layout>
