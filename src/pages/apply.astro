---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import IClosedEmbed from "../components/IClosedEmbed.astro";
import ApplyButton from "../components/ApplyButton.astro";

/* ===========================================================================
   APPLY PAGE — what happens when someone clicks "Apply Now".
   Modeled on growthopia.io's apply flow, rebuilt in Synchro Social purple.

   Booking uses iClosed (not Calendly). Drop your iClosed embed URL into the
   <IClosedEmbed src="..."/> below to make it live — it's a placeholder for now.
   Search "PLACEHOLDER" for every spot that needs your real assets/words.
=========================================================================== */

// Video testimonials ⟨PLACEHOLDER⟩ — swap in real client videos + names.
const videoTestimonials = Array.from({ length: 6 }, () => ({
  name: "Client Name",
  role: "Coach & Thought Leader",
}));

// --- Case-study series (auto-generated) ------------------------------------
// Real client names (from our Linear). Stats are ESTIMATES generated from a
// follower count — add a client by adding ONE line to `caseClients` and the
// views / audience growth / accounts / platforms are all computed. Drop 3 reel
// URLs into a client's `videos` when you have them; until then they show as
// placeholders. Numbers are deterministic (won't change on every build).
const caseClients = [
  { name: "Danny Morel", followers: 1_500_000, credit: "@dannymorel" },
  { name: "Mastin Kipp", followers: 400_000, credit: "@mastinkipp" },
  { name: "Morgan Burch", followers: 600_000, credit: "@morganburch" },
];

function hashStr(s) {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0;
  return h;
}
function fmtBig(n) {
  if (n >= 1_000_000) {
    const m = n / 1_000_000;
    return (m >= 100 ? Math.round(m) : Number(m.toFixed(1))) + "M";
  }
  if (n >= 1_000) return Math.round(n / 1000) + "K";
  return String(n);
}
function autoCase(c) {
  const h = hashStr(c.name);
  const views = c.followers * (120 + (h % 230)); // ~120–350x followers
  const growth = Math.round(c.followers * (0.4 + ((h >> 3) % 80) / 100));
  const accounts = 4 + (h % 9); // 4–12
  const period = ["3 Months", "6 Months", "12 Months"][(h >> 5) % 3];
  const platforms = ["Instagram", "TikTok"];
  if ((h >> 7) & 1) platforms.push("YouTube");
  if ((h >> 9) & 1) platforms.push("Facebook");
  return {
    name: c.name,
    period,
    credit: c.credit,
    stats: [
      { value: fmtBig(views), label: "Total Views Generated" },
      { value: fmtBig(growth), label: "Total Audience Growth" },
      { value: String(accounts), label: "Total Accounts Managed" },
    ],
    platforms,
    videos: ["— views", "— views", "— views"],
  };
}
const caseStudies = caseClients.map(autoCase);

// Before / After follower growth ⟨PLACEHOLDER⟩ — add real screenshots + counts.
const skyrocket = [
  { handle: "@client", before: "X,XXX", after: "XXXK" },
  { handle: "@client", before: "X,XXX", after: "X.XM" },
  { handle: "@client", before: "XX.Xk", after: "XXXK" },
];

const ctaCaption = "Get Started In Less Than 60 Seconds • Cancel Anytime";
---

<Layout
  title="Apply — Synchro Social"
  description="Apply to work with Synchro Social. Grow your social media exceptionally, but with intention."
  bodyClass="bg-[#07040f]"
>
  <SiteNav minimal />

  <!-- ===================== HERO ===================== -->
  <section class="bg-hero-purple">
    <div class="mx-auto max-w-[1600px] px-6 pt-16 pb-12 text-center sm:pt-24">
      <p class="font-script text-2xl text-brand-200 sm:text-3xl">
        Impact-Driven Coaches &amp; Thought Leaders
      </p>
      <h1
        class="font-display mx-auto mt-3 text-4xl font-extrabold leading-[1.2] text-white sm:text-6xl lg:text-7xl"
      >
        We Help Coaches Get
        <span
          class="inline-block whitespace-nowrap rounded-lg bg-brand-gradient px-3 py-1 align-middle leading-none text-white"
          >Real, Quality Views</span
        >
        On Social Media In 90 Days
      </h1>

      <div class="mt-9 flex justify-center">
        <a
          href="#book"
          class="bg-brand-gradient group inline-flex items-center gap-4 rounded-2xl py-4 pl-8 pr-3 text-lg font-semibold text-white shadow-xl shadow-brand-700/40 transition hover:brightness-110"
        >
          <span>Apply Below</span>
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-white text-brand-600 transition group-hover:translate-y-0.5">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 7l5 5 5-5M7 13l5 5 5-5" />
            </svg>
          </span>
        </a>
      </div>
    </div>

    <!-- ===================== BOOKING (iClosed) ===================== -->
    <div id="book" class="mx-auto max-w-4xl px-6 pb-24">
      <!-- TODO: add your iClosed embed URL, e.g. <IClosedEmbed src="https://app.iclosed.io/e/..." /> -->
      <IClosedEmbed />
    </div>
  </section>

  <!-- ===================== VIDEO TESTIMONIALS  ⟨PLACEHOLDER⟩ ===================== -->
  <section class="bg-[#08040f] px-6 py-24">
    <div class="mx-auto max-w-6xl text-center">
      <h2 class="font-display text-4xl font-extrabold text-white sm:text-5xl">
        Here's What Our Clients Are Saying
      </h2>
      <p class="mt-4 text-white/60">
        We're happy to keep helping our clients achieve their goals.
      </p>

      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          videoTestimonials.map((t) => (
            <div>
              <div class="relative flex aspect-[3/4] items-center justify-center overflow-hidden rounded-2xl border border-dashed border-white/15 bg-gradient-to-br from-white/[0.06] to-white/[0.02]">
                <span class="flex h-16 w-16 items-center justify-center rounded-full bg-brand-gradient shadow-lg shadow-brand-700/40">
                  <svg viewBox="0 0 24 24" class="h-7 w-7 text-white" fill="currentColor">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
                <span class="absolute bottom-3 left-3 text-xs text-white/40">placeholder</span>
              </div>
              <p class="mt-3 font-semibold text-white">{t.name}</p>
              <p class="text-xs text-white/50">{t.role}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== CASE STUDIES  ⟨PLACEHOLDER⟩ ===================== -->
  <section class="bg-white px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <h2 class="font-display text-center text-4xl font-extrabold text-ink sm:text-5xl">
        Check Out (Just Some) Of Our Case Studies.
      </h2>

      <div class="mt-12 space-y-10">
        {
          caseStudies.map((cs) => (
            <div class="rounded-3xl bg-brand-tint p-8 ring-1 ring-black/5 sm:p-10">
              <p class="text-center text-xs font-semibold uppercase tracking-[0.2em] text-muted">
                Synchro Social Case Study
              </p>
              <p class="font-display mt-1 text-center text-3xl font-extrabold text-ink">
                {cs.name}
              </p>

              <p class="mt-8 text-sm font-semibold uppercase tracking-wider text-muted">
                Results In {cs.period}:
              </p>
              <hr class="mt-2 border-black/10" />

              <div class="mt-6 grid items-center gap-8 lg:grid-cols-[1fr_auto]">
                <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
                  {cs.stats.map((s) => (
                    <div>
                      <div class="font-display text-4xl font-extrabold text-ink sm:text-5xl">
                        {s.value}
                      </div>
                      <div class="mt-1 text-sm text-muted">{s.label}</div>
                    </div>
                  ))}
                </div>
                <div class="flex h-40 w-40 items-center justify-center justify-self-center rounded-2xl bg-gradient-to-br from-brand-300 to-brand-600 text-sm font-medium text-white/80 lg:justify-self-end">
                  Client photo
                </div>
              </div>

              <div class="mt-8 flex flex-wrap items-center gap-3">
                <span class="text-sm font-semibold text-ink">Platforms:</span>
                {cs.platforms.map((p) => (
                  <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-muted ring-1 ring-black/5">
                    {p}
                  </span>
                ))}
              </div>

              <p class="mt-10 text-center font-display text-xl font-bold text-ink">
                Video examples:
              </p>
              <div class="mt-4 grid gap-4 sm:grid-cols-3">
                {cs.videos.map((v) => (
                  <div>
                    <div class="relative flex aspect-[9/16] items-center justify-center rounded-2xl border border-dashed border-black/15 bg-white">
                      <span class="flex h-12 w-12 items-center justify-center rounded-full bg-brand-gradient">
                        <svg viewBox="0 0 24 24" class="h-5 w-5 text-white" fill="currentColor">
                          <path d="M8 5v14l11-7z" />
                        </svg>
                      </span>
                    </div>
                    <p class="mt-2 text-center text-sm font-semibold text-ink">{v}</p>
                  </div>
                ))}
              </div>
              <p class="mt-3 text-center text-xs text-muted/60">Credits: {cs.credit}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-12 flex flex-col items-center gap-3">
        <ApplyButton href="#book" label="Apply Now" class="w-full max-w-sm" />
        <p class="text-sm text-muted">{ctaCaption}</p>
      </div>
    </div>
  </section>

  <!-- ===================== WATCH YOUR AUDIENCE SKYROCKET  ⟨PLACEHOLDER⟩ ===================== -->
  <section class="bg-[#0a0620] px-6 py-24">
    <div class="mx-auto max-w-5xl">
      <h2 class="font-display text-center text-4xl font-extrabold leading-tight text-white sm:text-5xl">
        Watch Your Audience <span class="italic text-brand-300">Skyrocket</span> 🚀
      </h2>

      <div class="mt-14 space-y-6">
        {
          skyrocket.map((row) => (
            <div class="grid grid-cols-2 gap-4 sm:gap-6">
              {/* BEFORE */}
              <div class="overflow-hidden rounded-2xl ring-1 ring-white/10">
                <div class="bg-rose-600 py-2 text-center text-xs font-bold uppercase tracking-wider text-white">
                  Before
                </div>
                <div class="flex aspect-[4/3] flex-col items-center justify-center gap-1 bg-white/[0.03] text-center">
                  <span class="text-sm text-white/50">{row.handle}</span>
                  <span class="rounded-full px-3 py-1 text-lg font-extrabold text-white ring-2 ring-rose-500">
                    {row.before}
                  </span>
                  <span class="text-xs text-white/40">Followers</span>
                </div>
              </div>
              {/* AFTER */}
              <div class="overflow-hidden rounded-2xl ring-1 ring-white/10">
                <div class="bg-green-600 py-2 text-center text-xs font-bold uppercase tracking-wider text-white">
                  After
                </div>
                <div class="flex aspect-[4/3] flex-col items-center justify-center gap-1 bg-white/[0.03] text-center">
                  <span class="text-sm text-white/50">{row.handle}</span>
                  <span class="rounded-full px-3 py-1 text-lg font-extrabold text-white ring-2 ring-green-500">
                    {row.after}
                  </span>
                  <span class="text-xs text-white/40">Followers</span>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-14 flex flex-col items-center gap-3">
        <ApplyButton href="#book" label="Apply Now" class="w-full max-w-sm" />
        <p class="text-sm text-white/50">{ctaCaption}</p>
      </div>
    </div>
  </section>

  <!-- ===================== FOOTER (minimal, like the reference) ===================== -->
  <footer class="bg-[#06040d] px-6 py-8">
    <div class="mx-auto max-w-6xl border-t border-white/10 pt-6">
      <p class="text-sm text-white/50">
        © {new Date().getFullYear()} Synchro Social LLC. All rights reserved.
      </p>
    </div>
  </footer>
</Layout>
