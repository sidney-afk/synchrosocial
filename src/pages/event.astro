---
import Layout from "../layouts/Layout.astro";

/* ===========================================================================
   EVENT HUB — Synchro Social branded "pick a path" page for Kasper to share
   at AI events (QR-code friendly, mobile-first, single screen).

   Three destinations. They WILL change (v2 goes to the real URL once
   approved) — edit them here:
=========================================================================== */
const LINKS = {
  company: "/",
  aiAvatar: "/ai-invite/",
  bookCall: "https://app.iclosed.io/e/synchrosocial/demo", // Kasper's demo calendar (iClosed)
  linkedin: "https://www.linkedin.com/in/kasper-hytonen",
};

const options = [
  {
    href: LINKS.company,
    title: "Learn More About Kasper's Company",
    desc: "Synchro Social — social media growth for coaches & thought leaders",
    icon: "company",
  },
  {
    href: LINKS.aiAvatar,
    title: "Learn About Creating an AI Avatar",
    desc: "Your AI clone that creates content without you ever filming",
    icon: "avatar",
  },
  {
    href: LINKS.bookCall,
    title: "Book a Call With Kasper",
    desc: "Find a time on his calendar — free, no strings attached",
    icon: "call",
  },
  {
    href: LINKS.linkedin,
    title: "Connect With Kasper on LinkedIn",
    desc: "Follow his journey and reach out directly",
    icon: "linkedin",
  },
];
---

<Layout
  title="Synchro Social — Great Meeting You!"
  description="Met Kasper at an event? Learn about Synchro Social, AI avatars, or book a call."
  bodyClass="bg-[#5c32bf]"
>
  <!-- Satoshi (Fontshare) -->
  <link
    rel="stylesheet"
    href="https://api.fontshare.com/v2/css?f[]=satoshi@300,500,700&display=swap"
  />

  <main
    class="flex min-h-[100svh] flex-col items-center justify-center bg-[linear-gradient(170deg,rgb(92,50,191)_0%,rgb(133,31,196)_100%)] px-5 py-10 text-center text-white"
  >
    <div class="w-full max-w-[560px]">
      <!-- Brand lockup -->
      <div class="inline-flex flex-col items-center" aria-label="Synchro Social">
        <img
          src="/images/logo.png"
          alt="Synchro Social"
          class="h-20 w-auto [filter:brightness(0)_invert(1)]"
        />
      </div>

      <!-- Kasper -->
      <img
        src="/images/kasper.jpg"
        alt="Kasper Hytonen"
        class="mx-auto mt-8 h-[120px] w-[120px] rounded-full object-cover ring-4 ring-white/80"
      />
      <h1 class="font-outfit mt-5 text-4xl font-semibold leading-tight max-sm:text-3xl">
        Great Meeting You!
      </h1>
      <p class="font-satoshi mx-auto mt-3 max-w-[420px] text-lg font-light leading-snug text-white/90">
        I'm Kasper, founder of Synchro Social. Pick where you'd like to go
        next:
      </p>

      <!-- Options -->
      <div class="mt-9 flex flex-col gap-4">
        {
          options.map((o) => (
            <a
              href={o.href}
              class="group flex items-center gap-4 rounded-3xl bg-white p-5 text-left shadow-[0_0_30px_3px_rgba(255,255,255,0.25)] transition hover:-translate-y-0.5 hover:shadow-[0_0_40px_6px_rgba(255,255,255,0.35)]"
            >
              <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-[linear-gradient(#69179c_0%,#282bb8_100%)] text-white">
                {o.icon === "company" && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 21h18M5 21V7a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v14M9 9h2M9 13h2M13 9h2M13 13h2M10 21v-4h4v4" />
                  </svg>
                )}
                {o.icon === "avatar" && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="8" r="4" />
                    <path d="M5 21c0-3.5 3-6 7-6s7 2.5 7 6" />
                    <path d="M19 3l.9 1.8L21.7 6l-1.8.9L19 9l-.9-2.1L16.3 6l1.8-1.2z" fill="currentColor" stroke="none" />
                  </svg>
                )}
                {o.icon === "call" && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="5" width="18" height="16" rx="3" />
                    <path d="M3 10h18M8 3v4M16 3v4M8.5 14.5h.01M12 14.5h.01M15.5 14.5h.01M8.5 17.5h.01M12 17.5h.01" />
                  </svg>
                )}
                {o.icon === "linkedin" && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor" stroke="none">
                    <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" />
                  </svg>
                )}
              </span>
              <span class="min-w-0 flex-1">
                <span class="font-outfit block text-lg font-semibold leading-snug text-[#1d1230] max-sm:text-base">
                  {o.title}
                </span>
                <span class="font-satoshi mt-0.5 block text-sm font-light leading-snug text-[#1d1230]/65">
                  {o.desc}
                </span>
              </span>
              <svg
                viewBox="0 0 24 24"
                class="h-5 w-5 shrink-0 text-[#69179c] transition group-hover:translate-x-0.5"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </a>
          ))
        }
      </div>

      <p class="font-satoshi mt-9 text-xs font-light text-white/60">
        © {new Date().getFullYear()} Synchro Social LLC
      </p>
    </div>
  </main>
</Layout>
