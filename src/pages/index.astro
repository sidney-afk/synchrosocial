---
import Layout from "../layouts/Layout.astro";

// Real content pulled from synchrosocial.com. This first-pass homepage is a
// working draft of the redesign — structure and copy are real; the exact
// visual styling and imagery get finalized once the screenshots land.
const stats = [
  { value: "1B+", label: "Content views" },
  { value: "63", label: "Clients helped" },
  { value: "23,000+", label: "Leads generated" },
  { value: "8M+", label: "Followers grown" },
];

const phases = [
  {
    step: "01",
    title: "Traffic",
    body: "We create scroll-stopping content that puts your message in front of the right audience, at scale.",
  },
  {
    step: "02",
    title: "Nurture",
    body: "We turn passive viewers into an engaged community that trusts you and looks forward to what's next.",
  },
  {
    step: "03",
    title: "Monetize",
    body: "We convert that attention into booked calls, qualified leads, and real revenue for your business.",
  },
];

const team = [
  { name: "Kasper Hytonen", role: "Founder & Strategy" },
  { name: "Sidney Laruel", role: "Operations Manager" },
  { name: "Rocio Perez", role: "Graphic Design" },
  { name: "Laura Ospina", role: "Social Media Manager" },
];
---

<Layout>
  <!-- Header -->
  <header class="sticky top-0 z-30 border-b border-black/5 bg-white/80 backdrop-blur">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="#top" class="text-lg font-extrabold tracking-tight">Synchro<span class="text-brand-600">Social</span></a>
      <div class="hidden items-center gap-8 text-sm font-medium text-muted md:flex">
        <a href="#approach" class="hover:text-ink">Approach</a>
        <a href="#results" class="hover:text-ink">Results</a>
        <a href="#team" class="hover:text-ink">Team</a>
      </div>
      <a
        href="#call"
        class="rounded-full bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-700"
      >
        Free audit call
      </a>
    </nav>
  </header>

  <main id="top">
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 -z-10 bg-gradient-to-b from-brand-50 to-white"></div>
      <div class="mx-auto max-w-6xl px-6 py-24 text-center md:py-32">
        <p class="mb-5 inline-block rounded-full border border-brand-200 bg-white px-4 py-1.5 text-sm font-medium text-brand-700">
          Grow exceptionally — but with intention
        </p>
        <h1 class="mx-auto max-w-4xl text-4xl font-extrabold leading-[1.1] tracking-tight md:text-6xl">
          We help impact-driven coaches and thought leaders share their journey on social media
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-muted">
          We take social media off your plate and turn it into a
          client-generating machine — so you can focus on the work only you
          can do.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href="#call"
            class="rounded-full bg-brand-600 px-7 py-3.5 text-base font-semibold text-white transition hover:bg-brand-700"
          >
            Schedule your free audit call
          </a>
          <a
            href="#approach"
            class="rounded-full border border-black/10 px-7 py-3.5 text-base font-semibold text-ink transition hover:bg-black/[0.03]"
          >
            See how it works
          </a>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section id="results" class="border-y border-black/5 bg-ink text-white">
      <div class="mx-auto grid max-w-6xl grid-cols-2 gap-8 px-6 py-14 md:grid-cols-4">
        {
          stats.map((s) => (
            <div class="text-center">
              <div class="text-4xl font-extrabold tracking-tight md:text-5xl">{s.value}</div>
              <div class="mt-2 text-sm font-medium text-white/60">{s.label}</div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Approach -->
    <section id="approach" class="mx-auto max-w-6xl px-6 py-24">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-extrabold tracking-tight md:text-4xl">A simple, intentional system</h2>
        <p class="mt-4 text-lg text-muted">
          Three phases that take you from invisible to in-demand.
        </p>
      </div>
      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {
          phases.map((p) => (
            <div class="rounded-2xl border border-black/5 bg-white p-8 shadow-sm transition hover:shadow-md">
              <div class="text-sm font-bold text-brand-600">{p.step}</div>
              <h3 class="mt-3 text-xl font-bold">{p.title}</h3>
              <p class="mt-3 text-muted">{p.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Team -->
    <section id="team" class="border-t border-black/5 bg-brand-50/40">
      <div class="mx-auto max-w-6xl px-6 py-24">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-extrabold tracking-tight md:text-4xl">The team behind the growth</h2>
          <p class="mt-4 text-lg text-muted">A small, results-driven team — fully remote.</p>
        </div>
        <div class="mt-14 grid grid-cols-2 gap-6 md:grid-cols-4">
          {
            team.map((m) => (
              <div class="rounded-2xl bg-white p-6 text-center shadow-sm">
                <div class="mx-auto h-20 w-20 rounded-full bg-gradient-to-br from-brand-200 to-brand-400" />
                <div class="mt-4 font-bold">{m.name}</div>
                <div class="text-sm text-muted">{m.role}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section id="call" class="mx-auto max-w-6xl px-6 py-24">
      <div class="rounded-3xl bg-brand-600 px-8 py-16 text-center text-white md:py-20">
        <h2 class="mx-auto max-w-2xl text-3xl font-extrabold tracking-tight md:text-4xl">
          Ready to grow with intention?
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-white/80">
          Book a free audit call and we'll map out exactly how to turn your
          social media into a client-generating machine.
        </p>
        <a
          href="#"
          class="mt-8 inline-block rounded-full bg-white px-8 py-3.5 text-base font-semibold text-brand-700 transition hover:bg-brand-50"
        >
          Speak to our team today
        </a>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-black/5">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-10 text-sm text-muted md:flex-row">
      <div>© {new Date().getFullYear()} Synchro Social Ltd. All rights reserved.</div>
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-ink">Privacy Policy</a>
        <a href="/terms" class="hover:text-ink">Terms of Service</a>
      </div>
    </div>
  </footer>
</Layout>
