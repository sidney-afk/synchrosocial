<Layout
  title="Synchro Social — Grow your social media, with intention"
  description="We help impact-driven coaches and thought leaders go viral and grow on social media. Grow exceptionally, but with intention."
  bodyClass="v2"
>
  <SiteNav />
  <IClosedLiftWidget />

  <!-- ===================== HERO ===================== -->
  <section class="relative pb-[120px] pt-20 max-lg:pb-[60px] max-lg:pt-10">
    <!-- Backdrop: transparent fading down to solid brand purple, spanning
         exactly the hero section (solid color lands at its bottom edge). -->
    <div class="bg-hero-fade pointer-events-none absolute inset-0" aria-hidden="true"></div>

    <div class="relative z-[3] mx-auto w-[95%] max-w-[1040px]">
      <!-- Heading block -->
      <div class="flex w-full flex-col items-center gap-4 text-center max-md:gap-2">
        <p class="font-script text-2xl font-bold capitalize leading-[157%] text-[#b794ff] max-md:hidden">
          Impact-Driven Coaches, Thought Leaders &amp; Experts
        </p>
        <h1 class="font-tight text-[56px] font-bold capitalize leading-[1.05] text-white max-md:text-[32px]">
          We Help Impact-Driven Coaches and Thought Leaders Go Viral and Grow On Social Media
        </h1>
        <div class="my-3 max-w-[686px]">
          <p class="text-xl leading-[157%] max-md:text-lg">
            Stop worrying about where the next client is going to come from.
            It's time to blow up your social media and stay focused on what
            matters the most:
            <span class="font-semibold text-white">your business.</span>
          </p>
        </div>

        <!-- Button + social proof -->
        <div class="flex w-full max-w-[457px] flex-col gap-6 max-md:w-[calc(100vw-32px)] max-md:max-w-none">
          <ApplyButton href="/apply" label="Apply Now" class="w-full" />
          <div class="flex w-max items-center justify-center gap-4 self-center max-sm:w-full max-sm:flex-col">
            <div class="flex -space-x-1">
              {
                heroFaces.map((c) => (
                  <div class="hero-proof-avatar rounded-full ring-2 ring-white max-md:ring-[3px] max-md:ring-black">
                    <Avatar name={c.name} src={c.img} size={48} ring={false} />
                  </div>
                ))
              }
            </div>
            <div class="flex flex-col items-start gap-1.5 max-sm:items-center">
              <div class="flex gap-1 text-[var(--g-purple)] max-md:gap-1.5 max-md:text-[#d64cff]">
                {
                  Array.from({ length: 5 }).map(() => (
                    <svg viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5 max-md:h-6 max-md:w-6">
                      <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L10 15l-5.2 2.6 1-5.8L1.5 7.7l5.9-.9z" />
                    </svg>
                  ))
                }
              </div>
              <p class="whitespace-nowrap text-sm leading-[120%] text-[#e9e9e9] max-sm:whitespace-normal">
                Trusted by 100+ coaches &amp; thought leaders
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== LEADERS / CLIENT CARDS ===================== -->
  <section id="results" class="w-full overflow-hidden py-[120px] max-lg:py-[60px]">
    <div class="mx-auto w-[95%] max-w-[1040px]">
      <ul class="grid w-full grid-cols-4 gap-5 max-lg:grid-cols-3 max-md:grid-cols-2 max-md:gap-4">
          {
            clients.map((c) => (
              <li class="shadow-soft-dark flex items-center justify-center gap-3 rounded-xl bg-[#262626] px-5 py-4 max-md:min-h-[122px] max-md:justify-start max-sm:flex-col max-sm:items-start max-sm:gap-2 max-sm:p-4">
                <div class="client-card-avatar">
                  <Avatar name={c.name} src={c.img} size={59} ring={false} />
                </div>
                <div class="flex min-w-0 flex-col items-start gap-1.5">
                  <p class="max-w-full truncate text-lg font-medium leading-[120%] text-white max-md:text-base">
                    <span class="max-md:hidden">{c.name}</span>
                    <span class="hidden max-md:inline">{c.handle}</span>
                  </p>
                  <p class="text-base leading-[120%] text-[#c4c4c4] max-md:text-sm">
                    {compactCount(c.followers)} Followers
                  </p>
                </div>
              </li>
            ))
          }
      </ul>
    </div>

    <!-- ⟨PLACEHOLDER⟩ proof marquee — swap reels for real client result
         screenshots (IG growth, DMs) when you have them. -->
