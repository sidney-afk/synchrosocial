// Marquee cards crop like real phone screenshots: repeat each account's three
// reels so tall cards stay filled, alternating order so rows don't twin.
const reelRows = (reels: { img: string; views: string }[]) => [
  ...reels,
  ...[...reels].reverse(),
  ...reels,
  ...[...reels].reverse(),
];

// "1,500,000+" → "1.5M+" so follower counts stay on one line in the cards.
const compactCount = (s: string) =>
  s.replace(/^(\d{1,3}(?:,\d{3})*)(\+?)$/, (_, num, plus) => {
    const n = parseInt(num.replace(/,/g, ""), 10);
    const compact =
      n >= 1e6
        ? `${(n / 1e6).toFixed(n % 1e6 ? 1 : 0).replace(/\.0$/, "")}M`
        : n >= 1e3
          ? `${Math.round(n / 1e3)}K`
          : String(n);
    return compact + plus;
  });
