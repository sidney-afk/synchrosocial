                        <div class="flex h-full w-full items-center justify-center text-sm font-bold text-white">
                          {c.handle.replace("@", "").slice(0, 2).toUpperCase()}
                        </div>
                        <img
                          src={`/images/clients/${c.pic}.jpg`}
                          alt=""
                          class="absolute inset-0 h-full w-full object-cover"
                          onerror="this.style.display='none'"
                        />
                      </div>
                      <div class="min-w-0">
                        <p class="truncate text-sm font-bold leading-tight text-[#262626]">
                          {c.handle}
                        </p>
                        <p class="text-xs leading-tight text-[#555]">
                          {c.followers} followers
                        </p>
                      </div>
                      <svg
                        viewBox="0 0 24 24"
                        class="ml-auto h-5 w-5 text-[#262626]"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <rect x="3" y="3" width="18" height="18" rx="5" />
                        <circle cx="12" cy="12" r="4" />
                        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                      </svg>
                    </div>
                    <div class="grid grid-cols-3 gap-px bg-black/10">
                      {reelRows(c.reels).map((r) => (
                        <div class="relative aspect-[9/16] bg-black">
                          <img
                            src={`/images/reels/${r.img}.jpg`}
                            alt=""
                            loading="lazy"
                            class="absolute inset-0 h-full w-full object-cover"
                          />
                          <span class="absolute bottom-1 left-1 flex items-center gap-0.5 text-[0.62rem] font-semibold text-white [text-shadow:0_1px_2px_rgba(0,0,0,0.85)]">
                            <svg viewBox="0 0 24 24" class="h-2.5 w-2.5" fill="currentColor">
                              <path d="M8 5v14l11-7z" />
                            </svg>
                            {r.views}
                          </span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
  </section>

  <!-- ===================== LIGHT BAND: 3-STEP + FEATURE GRID ===================== -->
  <div class="bg-brand-tint flex flex-col gap-40 py-[120px] text-black max-lg:gap-[60px] max-lg:py-[60px]">
    <!-- 3-step formula -->
    <section class="w-full">
      <div class="mx-auto flex w-[95%] max-w-[1040px] flex-col items-center gap-[60px] max-lg:gap-[30px]">
        <div class="flex w-full max-w-[686px] flex-col items-center gap-4 text-center max-md:gap-2">
          <p class="font-script text-2xl capitalize leading-[157%] text-[var(--g-purple)]">Our Process</p>
          <h2 class="font-tight text-5xl font-bold capitalize leading-none text-black max-md:text-[28px]">
            Our Proven 3-Step Formula
          </h2>
          <div class="mt-2 max-w-[686px]">
            <p class="text-xl leading-[157%] text-[#555] max-md:text-lg">
              Our process can be summarized into three steps — designed to grow
              your brand exceptionally, but with intention.
            </p>
          </div>
        </div>

        <div class="grid w-full grid-cols-3 gap-5 max-md:grid-cols-1">
          {
            steps.map((s) => (
              <div class="flex flex-col overflow-hidden rounded-xl bg-white">
                <div class="relative flex aspect-[333/235] w-full items-center justify-center bg-white">
                  <img
                    src={s.image}
                    alt=""
                    class="h-full w-full object-contain"
                    loading="lazy"
                  />
                  <span class="absolute left-4 top-4 flex h-8 w-8 items-center justify-center rounded-full bg-[var(--g-purple)] text-sm font-bold text-white">
                    {s.n}
                  </span>
                </div>
                <div class="flex h-full flex-col gap-3 px-6 pb-6 max-sm:gap-2 max-sm:px-4 max-sm:pb-4">
                  <h3 class="text-2xl font-bold capitalize leading-none text-[#262626]">
                    {s.title}
                  </h3>
                  <p class="text-base leading-[157%] text-[#555]">{s.body}</p>
                  <a
                    href="/apply"
                    class="mt-auto flex items-center justify-center gap-2 py-3 text-base font-semibold capitalize leading-[150%] text-[var(--g-purple)]"
                  >
                    Apply Now
                    <svg
                      viewBox="0 0 24 24"
                      class="h-6 w-6"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M13.21 8.96L16.25 12l-3.04 3.04M7.75 12h8.43" />
