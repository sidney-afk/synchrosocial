---
import Layout from "../layouts/Layout.astro";
import Avatar from "../components/Avatar.astro";
import CalendlyEmbed from "../components/CalendlyEmbed.astro";

/* ===========================================================================
   HOMEPAGE — matched to the production Framer page at synchrosocial.com
   (measured in-browser), tidied where the original was rough.

   Design system (from the live page):
     • Stacked full-width bands, each with 40px rounded bottom corners,
       alternating white / purple. Purple bands:
         leaders+booking  #5c32bf → #851fc4
         stats            #4a1fad → #7811b8
     • Gradient display text (#851fc4 → #5c32bf, bottom→top) for the hero
       headline and OUR APPROACH.
     • Fonts: Outfit (display + hero sub + captions) and Satoshi (body,
       step text, stats, A-team, booking) — same pairing as /ai.
     • CTA: purple→blue gradient pill (#69179c → #282bb8) with a soft
       lavender glow. Hero 577×88 (24px label), sections ~380×55 / 356×67.
=========================================================================== */

const clients = [
  { name: "Danny Morel", followers: "1,500,000+", img: "/images/danny-morel.jpg" },
  { name: "Alexi Panos", followers: "150,000+", img: "/images/alexi.jpg" },
  { name: "Garrain Jones", followers: "300,000+", img: "/images/garrain.jpg" },
  { name: "Morgan Burch", followers: "600,000+", img: "/images/morgan.jpg" },
  { name: "Stefanos Sifandos", followers: "200,000+", img: "/images/stefanos.jpg" },
  { name: "Lucas Salame", followers: "140,000+", img: "/images/lucas.jpg" },
  { name: "Daniel Raphael", followers: "100,000+", img: "/images/daniel.jpg" },
  { name: "Baya Voce", followers: "350,000+", img: "/images/baya.jpg" },
  { name: "Kute Blackson", followers: "300,000+", img: "/images/kute.jpg" },
  { name: "Mastin Kipp", followers: "400,000+", img: "/images/mastin.jpg" },
  { name: "Tu Lam", followers: "640,000+", img: "/images/tu-lam.jpg" },
  { name: "Jessica Winterstern", followers: "100,000+", img: "/images/jessica.jpg" },
];

const approach = [
  {
    n: "1",
    title: "Generate traffic",
    body: "We first study your audience to deeply understand their interests, behaviors, motivators and emotional drivers. Based on this data we work on your messaging by coming up with the best angles and hooks to use on your content and follower growth efforts.",
  },
  {
    n: "2",
    title: "Nurture traffic",
    body: "After we have grown followers, either organically or through influencer marketing, we continue nurturing your new audience by creating highly engaging content.",
  },
  {
    n: "3",
    title: "Monetize traffic",
    body: "Once we have an audience that has been nurtured, we monetize it by generating leads on autopilot by using advanced content & back-end technology.",
  },
];

const stats = [
  { value: "63", label: "CLIENTS HELPED" },
  { value: "23K+", label: "LEADS GENERATED" },
  { value: "8M+", label: "FOLLOWERS GROWN" },
];

const team = [
  { name: "Kasper Hytonen", role: "Founder & Strategy", img: "/images/kasper.jpg" },
  { name: "Rocio Perez", role: "Graphic Design", img: "/images/rocio.jpg" },
  { name: "Sidney Laruel", role: "Operations Manager", img: "/images/sidney.jpg" },
  { name: "Laura Ospina", role: "Social Media Manager", img: "/images/laura.jpg" },
];

const perfectFor = [
  "Coaches and leaders looking to remove the headache of trying to grow & manage their social media on their own.",
  "Coaches and leaders looking to convert their current social media into a high quality & streamlined funnel format.",
  "Coaches and leaders looking to stop doing cold outreach and get leads on autopilot.",
  "Coaches and leaders looking for a team that truly understands them, their brand and their messaging.",
  "Coaches and leaders looking for a reliable agency that can make their company a priority.",
];

/* Gradient display text + CTA pill (shared looks) */
const gradText =
  "bg-[linear-gradient(0deg,#851fc4_0%,#5c32bf_100%)] bg-clip-text text-transparent";
const pill =
  "inline-flex items-center justify-center rounded-full bg-[linear-gradient(#69179c_0%,#282bb8_100%)] font-satoshi font-medium text-white shadow-[0_1px_2px_-1px_rgba(131,117,255,0.72),0_3px_6px_-2px_rgba(131,117,255,0.6),0_12px_24px_-4px_rgba(131,117,255,0.5)] transition hover:brightness-110";
---

<Layout
  title="Synchro Social — Social media growth for coaches & thought leaders"
  description="We help impact-driven coaches and thought leaders go viral and grow on social media. Grow exceptionally, but with intention."
  bodyClass="bg-white"
>
  <!-- Satoshi (Fontshare) -->
  <link
    rel="stylesheet"
    href="https://api.fontshare.com/v2/css?f[]=satoshi@300,500,700&display=swap"
  />

  <main class="overflow-clip bg-white">
    <!-- ===================== HERO (white) ===================== -->
    <section class="relative z-[7] rounded-b-[40px] bg-white pb-9 pt-[60px] text-center">
      <img
        src="/images/logo.png"
        alt="Synchro Social"
        class="mx-auto h-16 w-auto"
      />
      <h1
        class={`font-outfit mx-auto mt-4 max-w-[1051px] px-6 text-[61px] font-semibold leading-[1.3] max-lg:text-[44px] max-md:text-[32px] ${gradText}`}
      >
        We Help Impact-Driven Coaches and Thought Leaders Go Viral and Grow On
        Social Media
      </h1>
      <h2 class="font-outfit mx-auto mt-7 max-w-[1008px] px-6 text-[22px] font-light leading-[1.3] tracking-[0.88px] text-black max-md:text-lg">
        Stop worrying about where the next client is going to come from. It's
        time to blow up your social media and have you focused on what matters
        the most: <strong class="font-semibold">your business.</strong>
      </h2>
      <div class="mt-3 flex justify-center px-6">
        <a href="#book" class={`${pill} h-[88px] w-[577px] max-w-full text-2xl max-md:h-16 max-md:text-lg`}>
          Speak To Our Team Today
        </a>
      </div>
    </section>

    <!-- ===================== LEADERS (purple) ===================== -->
    <section
      class="relative z-[6] -mt-10 rounded-b-[40px] bg-[linear-gradient(rgb(92,50,191)_0%,rgb(133,31,196)_100%)] pb-12 pt-[105px] text-center text-white"
    >
      <h2 class="font-outfit text-[46px] font-semibold leading-[1.3] max-md:text-[30px]">
        LEADERS WE'VE WORKED WITH
      </h2>
      <p class="font-outfit mt-0 text-sm font-light tracking-[0.56px] text-white">
        Here are a few notable leaders we have worked with...
      </p>
      <ul class="mx-auto mt-20 grid max-w-[1280px] grid-cols-6 gap-y-10 px-6 max-lg:grid-cols-3 max-md:grid-cols-2 max-md:mt-10">
        {
          clients.map((c) => (
            <li class="flex flex-col items-center">
              <Avatar name={c.name} src={c.img} size={132} />
              <span class="font-outfit mt-3 text-base font-medium tracking-[0.64px]">
                {c.name}
              </span>
              <span class="font-outfit text-[13px] font-light tracking-[0.5px] text-white/85">
                {c.followers} Followers
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- ===================== OUR APPROACH (white) ===================== -->
    <section class="relative z-[5] -mt-10 rounded-b-[40px] bg-white pb-16 pt-[100px]">
      <div class="text-center">
        <h2 class={`font-outfit text-[76px] font-semibold leading-[1.3] max-lg:text-[52px] max-md:text-[38px] ${gradText}`}>
          OUR APPROACH
        </h2>
        <p class="font-outfit text-[22px] font-light italic leading-[1.3] tracking-[0.88px] text-black max-md:text-lg">
          "Grow exceptionally but with intention"
        </p>
      </div>

      <div class="mx-auto mt-16 flex max-w-[1040px] items-start justify-between gap-12 px-6 max-md:flex-col max-md:items-center">
        <div class="w-full max-w-[442px]">
          <p class="font-outfit text-[29px] font-medium leading-[1.2] text-black max-md:text-2xl">
            3-STEP MODERN DAY ALCHEMY
          </p>
          <div class="font-satoshi mt-8 space-y-6 text-left text-[19px] font-light leading-[1.5] text-black">
            {
              approach.map((a) => (
                <p>
                  <strong class="font-bold">
                    {a.n}) {a.title}:
                  </strong>{" "}
                  {a.body}
                </p>
              ))
            }
          </div>
          <div class="mt-10 flex flex-col items-center gap-4">
            <a href="#book" class={`${pill} h-[55px] w-[380px] max-w-full text-base`}>
              Speak To Our Team Today
            </a>
            <p class="font-outfit text-base font-light tracking-[0.64px] text-black">
              Schedule Your FREE Audit Call Now
            </p>
          </div>
        </div>

        <img
          src="/images/phone.png"
          alt="Grow your brand on social media"
          class="w-full max-w-[397px] max-md:max-w-[320px]"
          loading="lazy"
        />
      </div>
    </section>

    <!-- ===================== STATS (purple) ===================== -->
    <section
      class="relative z-[4] -mt-10 rounded-b-[40px] bg-[linear-gradient(rgb(74,31,173)_0%,rgb(120,17,184)_100%)] pb-20 pt-[110px] text-center text-white"
    >
      <h2 class="font-outfit text-[94px] font-extrabold leading-[0.7] max-lg:text-[64px] max-md:text-[44px]">
        OVER 1 BILLION
      </h2>
      <p class="font-outfit mt-4 text-[36px] font-semibold leading-[1.3] max-md:text-2xl">
        TOTAL CONTENT VIEWS
      </p>
      <div class="mx-auto mt-[88px] flex max-w-[1040px] items-stretch justify-center gap-8 px-6 max-md:mt-10 max-md:flex-col max-md:items-center">
        {
          stats.map((s) => (
            <div class="flex h-[226px] w-[314px] max-w-full flex-col items-center justify-center rounded-[61px] bg-white text-[#303030] shadow-[0_0_30px_3px_rgba(255,255,255,0.45)]">
              <div class="font-satoshi text-[60px] font-bold leading-none">{s.value}</div>
              <div class="font-satoshi mt-3 text-[22px] font-bold leading-[1.2]">{s.label}</div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ===================== MEET THE A-TEAM (white) ===================== -->
    <section class="relative z-[3] -mt-10 rounded-b-[40px] bg-white pb-16 pt-[100px]">
      <div class="mx-auto flex max-w-[1040px] items-center justify-between gap-12 px-6 max-md:flex-col">
        <div class="grid w-full max-w-[420px] grid-cols-2 gap-x-8 gap-y-8">
          {
            team.map((m) => (
              <div class="flex flex-col items-center text-center">
                <Avatar name={m.name} src={m.img} size={130} />
                <span class="font-satoshi mt-3 text-[15px] font-bold text-black">
                  {m.name}
                </span>
                <span class="font-satoshi text-[13px] font-light text-black/70">
                  {m.role}
                </span>
              </div>
            ))
          }
        </div>

        <div class="w-full max-w-[528px]">
          <h2 class="font-satoshi text-[50px] font-bold leading-[1.2] text-black max-md:text-4xl">
            MEET THE A-TEAM
          </h2>
          <p class="font-satoshi mt-4 text-[17px] font-light leading-[1.5] text-black">
            Founded by Kasper Hytonen who has spent the past 5 years perfecting
            the craft of high-quality social media growth and lead generation.
          </p>
          <p class="font-satoshi mt-4 text-[17px] font-light leading-[1.5] text-black">
            With the elusive company culture & calibre of clientele Kasper has
            built, Synchro Social has become the go-to social media marketing
            agency that offers coaches and thought leaders less clutter and
            more certainty.
          </p>
          <div class="mt-9 flex flex-col items-center gap-4">
            <a href="#book" class={`${pill} h-[67px] w-[356px] max-w-full text-base`}>
              Speak To Our Team Today
            </a>
            <p class="font-outfit text-base font-light tracking-[0.64px] text-black">
              Schedule Your FREE Audit Call Now
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== BOOKING (purple) ===================== -->
    <section
      id="book"
      class="relative z-[2] -mt-10 rounded-b-[40px] bg-[linear-gradient(rgb(92,50,191)_0%,rgb(133,31,196)_100%)] pb-24 pt-[120px] text-white"
    >
      <div class="mx-auto grid max-w-[1240px] items-start gap-12 px-6 lg:grid-cols-2">
        <div class="order-2 lg:order-1">
          <CalendlyEmbed slug="kasper-synchro/demo" />
        </div>
        <div class="order-1 max-w-[686px] lg:order-2">
          <p class="font-satoshi text-[13px] font-bold uppercase tracking-[2px] text-white/85">
            Schedule Your Call With Kasper
          </p>
          <h2 class="font-satoshi mt-2 text-[43px] font-bold leading-[1.2] max-md:text-3xl">
            Free 30-Minute Audit Call
          </h2>
          <p class="font-satoshi mt-5 text-[19px] font-light leading-[1.2]">
            By the end of this audit call, you will have a clear understanding
            of the next steps you can take for your business to start
            generating consistent and reliable content, lead generation and
            growth results on social media.
          </p>
          <p class="font-satoshi mt-4 text-[19px] font-light leading-[1.2]">
            Find a time on Kasper's calendar to schedule your call today and we
            look forward to speaking to you soon!
          </p>
          <h3 class="font-satoshi mt-10 text-[26px] font-bold uppercase leading-[1.3]">
            This Audit Call Is Perfect For:
          </h3>
          <ul class="font-satoshi mt-4 space-y-3 text-[19px] font-light leading-[1.55]">
            {perfectFor.map((item) => <li>• {item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <!-- ===================== FOOTER (white) ===================== -->
    <footer class="relative z-[1] -mt-10 bg-white pb-10 pt-[70px] text-center">
      <img
        src="/images/logo.png"
        alt="Synchro Social"
        class="mx-auto h-20 w-auto"
      />
      <div class="font-satoshi mt-6 flex items-center justify-center gap-4 text-sm text-black">
        <a href="/privacypolicy" class="hover:underline">Privacy Policy</a>
        <a href="/terms-conditions" class="hover:underline">Terms of Service</a>
      </div>
      <p class="font-satoshi mx-auto mt-6 max-w-[1200px] px-6 text-[13px] leading-relaxed text-black">
        NOT FACEBOOK: This site is not a part of the Facebook website or
        Facebook Inc. Additionally, This site is NOT endorsed by Facebook in any
        way. FACEBOOK is a trademark of FACEBOOK, Inc.
      </p>
    </footer>
  </main>
</Layout>
