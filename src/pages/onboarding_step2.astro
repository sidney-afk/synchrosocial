---
import OnboardingStep from "../components/OnboardingStep.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import Button from "../components/Button.astro";

const formUrl =
  "https://dear-scorpion-b2e.notion.site/283bcb82c4bf81dbb384d881036c5afd?pvs=105";
---

<OnboardingStep
  theme="dark"
  tone="brand"
  step={2}
  title="Complete This Form"
  next={{ href: "/onboarding_step3", label: "Take Me To The Next Step (3/4)" }}
>
  <VideoEmbed
    provider="youtube"
    id="DKLQtOP28QI"
    title="How to complete the onboarding form"
    tone="brand"
  />

  <div class="mt-5 flex flex-col items-center">
    <Button href={formUrl} tone="brand" size="lg" target="_blank" rel="noopener">
      Fill In Form: General Onboarding Info
    </Button>
    <p class="mt-3 text-[0.7rem] font-medium uppercase tracking-wider text-white/50">
      Fill this form before moving to the next step
    </p>
  </div>
</OnboardingStep>
