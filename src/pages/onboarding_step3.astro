---
import OnboardingStep from "../components/OnboardingStep.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import IClosedEmbed from "../components/IClosedEmbed.astro";
---

<OnboardingStep
  theme="dark"
  tone="brand"
  step={3}
  title="Strategy Session"
  next={{ href: "/onboarding_step4", label: "Take Me To The Next Step (4/4)" }}
>
  <VideoEmbed
    provider="wistia"
    id="19g7o47in3"
    title="Your strategy session"
    tone="brand"
  />

  <div class="mt-5">
    <p class="mb-4 text-center text-sm text-white/70">
      Schedule your first strategy session with Synchro Social.
    </p>
    <IClosedEmbed linkPrefix="synchrosocial/kickoff-call" />
  </div>
</OnboardingStep>
