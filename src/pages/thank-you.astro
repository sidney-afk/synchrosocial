---
import Layout from "../layouts/Layout.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<Layout title="You're Booked! — Synchro Social">
  <main class="mx-auto flex max-w-3xl flex-col px-6 py-20 sm:py-28">
    <h1
      class="font-display text-center text-5xl font-extrabold text-brand-600 sm:text-6xl"
    >
      YOU'RE BOOKED!
    </h1>
    <p class="mt-5 text-center text-lg font-medium text-ink">
      It's time to get ready.
    </p>

    <div class="mt-10 space-y-4 text-base leading-relaxed text-muted">
      <p>
        I sent you an email confirming the date/time. Please mark this in your
        calendar now. Myself, or someone on my team will call you via Zoom or
        phone at the time that you selected. If you selected Zoom call, please
        check your email for our meeting room link.
      </p>
      <p>
        Please make sure you're in a quiet room, no airports, no calls while
        driving, etc.
      </p>
      <p>I look forward to helping you grow.</p>
      <p class="font-semibold text-ink">– Kasper</p>
    </div>
  </main>

  <SiteFooter tone="brand" />
</Layout>
