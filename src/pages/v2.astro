---

<Layout
  title="Synchro Social — Grow your social media, with intention"
  description="We help impact-driven coaches and thought leaders share their journey on social media. Grow exceptionally, but with intention."
  bodyClass="bg-[#07040f]"
>
  <SiteNav />

  <!-- ===================== HERO ===================== -->
  <section class="bg-hero-purple">
    <div class="mx-auto max-w-5xl px-6 pt-20 pb-28 text-center sm:pt-28">
      <p class="font-script text-2xl text-brand-200 sm:text-3xl">
        Impact-Driven Coaches &amp; Thought Leaders
      </p>
      <h1
        class="font-display mx-auto mt-4 max-w-4xl text-4xl font-extrabold leading-[1.05] text-white sm:text-6xl"
      >
        We Help You Share Your Journey On Social Media
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-white/75 sm:text-xl">
        Stop worrying about where the next client is going to come from. It's
        time to blow up your social media and stay focused on what matters the
        most: <span class="font-semibold text-white">your business.</span>
      </p>

      <div class="mt-10 flex justify-center">
        <ApplyButton href="/apply" label="Apply Now" class="w-full max-w-md" />
      </div>

      <!-- Social proof -->
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
        <div class="flex -space-x-3">
          {
            heroFaces.map((c) => (
              <div class="rounded-full ring-2 ring-[#1a0b33]">
                <Avatar name={c.name} src={c.img} size={44} />
              </div>
            ))
          }
        </div>
        <div class="text-left">
          <div class="flex gap-0.5 text-brand-300">
            {
              Array.from({ length: 5 }).map(() => (
                <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                  <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L10 15l-5.2 2.6 1-5.8L1.5 7.7l5.9-.9z" />
                </svg>
              ))
            }
          </div>
          <p class="text-sm text-white/80">
            Trusted by 60+ coaches &amp; thought leaders
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== LEADERS / CLIENT CARDS ===================== -->
  <section id="results" class="bg-[#08040f] px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <h2 class="font-display text-center text-2xl font-extrabold text-white sm:text-3xl">
        Leaders We've Worked With
      </h2>
      <p class="mt-2 text-center text-sm text-white/50">
        A few of the notable leaders we've helped grow.
      </p>
      <ul class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          clients.map((c) => (
            <li class="flex items-center gap-4 rounded-2xl bg-white/[0.03] p-4 ring-1 ring-white/5">
              <Avatar name={c.name} src={c.img} size={52} class="rounded-xl" />
              <div class="min-w-0">
                <p class="truncate font-semibold text-white">{c.name}</p>
                <p class="text-sm text-white/50">{c.followers} Followers</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ===================== PROOF SCROLLER  ⟨PLACEHOLDER⟩ ===================== -->
  <!-- Swap these for your real client screenshots (IG growth, DMs, results). -->
  <section class="bg-[#08040f] px-6 pb-20">
    <div class="mx-auto max-w-6xl">
      <div class="flex gap-5 overflow-x-auto pb-4 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        {
          Array.from({ length: 6 }).map(() => (
            <div class="flex h-96 w-52 shrink-0 flex-col items-center justify-center rounded-[2rem] border border-dashed border-white/15 bg-white/[0.02] text-center">
              <Icon name="smartphone" class="h-10 w-10 text-white/25" />
              <p class="mt-3 px-6 text-sm text-white/40">Your client result screenshot</p>
              <p class="mt-1 text-xs text-white/25">placeholder</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== 3-STEP FORMULA ===================== -->
  <section class="bg-brand-tint px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <p class="font-script text-2xl text-brand-500">Our Process</p>
        <h2 class="font-display mt-1 text-4xl font-extrabold text-ink sm:text-5xl">
          Our Proven 3-Step Formula
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-muted">
          Our process can be summarized into three steps — designed to grow your
          brand exceptionally, but with intention.
        </p>
      </div>

      <div class="mt-16 grid gap-8 lg:grid-cols-3">
        {
          steps.map((s) => (
            <div class="flex flex-col rounded-3xl bg-white p-8 shadow-xl shadow-brand-900/5 ring-1 ring-black/5">
              <div class="relative flex h-40 items-center justify-center overflow-hidden rounded-2xl bg-brand-tint">
                <Icon name={s.icon} class="h-16 w-16 text-brand-500" />
                <span class="absolute left-4 top-4 flex h-8 w-8 items-center justify-center rounded-full bg-brand-gradient text-sm font-bold text-white">
                  {s.n}
                </span>
              </div>
              <h3 class="font-display mt-6 text-xl font-bold text-ink">{s.title}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{s.body}</p>
              <a
                href="/apply"
                class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand-600 hover:gap-3"
              >
                Apply Now
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== FEATURE GRID ===================== -->
  <section id="features" class="bg-brand-tint px-6 pb-24">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <p class="font-script text-2xl text-brand-500">What You Get</p>
        <h2 class="font-display mt-1 text-4xl font-extrabold text-ink sm:text-5xl">
          Here's What's Waiting For You
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-muted">
          Say goodbye to empty metrics and hello to real results. With our
          system you don't just grow — you grow with intention.
        </p>
      </div>

      <div class="mx-auto mt-14 overflow-hidden rounded-3xl bg-black/[0.06] shadow-xl ring-1 ring-black/5">
        <div class="grid grid-cols-2 gap-px lg:grid-cols-4">
          {
            features.map((f, i) => (
              <div
                class={`bg-white p-6 text-center ${i === features.length - 1 ? "col-span-2 lg:col-span-4" : ""}`}
              >
                <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
                  <Icon name={f.icon} class="h-6 w-6" />
                </div>
                <h3 class="mt-4 text-sm font-bold text-ink">{f.title}</h3>
                <p class="mx-auto mt-1.5 max-w-xs text-xs leading-relaxed text-muted">
                  {f.desc}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CUSTOMER STORIES  ⟨PLACEHOLDER⟩ ===================== -->
  <section class="bg-[#08040f] px-6 py-24">
    <div class="mx-auto max-w-6xl text-center">
      <h2 class="font-display text-4xl font-extrabold text-white sm:text-5xl">
        Here's What Our Clients Are Saying
      </h2>
      <p class="mt-4 text-white/60">
        We're here to help our clients reach their goals — and keep reaching new ones.
      </p>

      <!-- Story tabs (placeholder) -->
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        {
          storyTabs.map((t, i) => (
            <div
              class={`rounded-xl border px-5 py-3 text-left ${i === 0 ? "border-brand-400/40 bg-white/[0.06]" : "border-white/10 bg-white/[0.02]"}`}
            >
              <p class="font-semibold text-white">{t.name}</p>
              <p class="text-xs text-white/50">{t.role}</p>
            </div>
          ))
        }
      </div>

      <!-- Featured story card (placeholder) -->
      <div class="mt-10 grid items-center gap-8 rounded-3xl bg-white/[0.03] p-6 text-left ring-1 ring-white/5 lg:grid-cols-2 lg:p-10">
        <div class="flex aspect-video items-center justify-center rounded-2xl border border-dashed border-white/15 bg-black/40">
          <span class="flex h-16 w-16 items-center justify-center rounded-full bg-brand-gradient">
            <svg viewBox="0 0 24 24" class="h-7 w-7 text-white" fill="currentColor">
              <path d="M8 5v14l11-7z" />
            </svg>
          </span>
        </div>
        <div>
          <h3 class="font-display text-2xl font-bold text-white">
            [Add your client's headline result here]
          </h3>
          <p class="mt-4 leading-relaxed text-white/70">
            Drop in a real client story — where they started, what we did
            together, and the growth and lead-generation results they saw. This
            placeholder is here so the layout looks complete until you add the
            video and write-up.
          </p>
        </div>
      </div>

      <div class="mt-12 flex flex-col items-center gap-3">
        <ApplyButton href="/apply" label="Apply Now" class="w-full max-w-sm" />
        <p class="text-sm text-white/50">
          Get Started In Less Than 60 Seconds • Speak To Our Team Today
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== WHY WE'RE DIFFERENT ===================== -->
  <section class="bg-[#07040f] px-6 py-24">
    <div class="mx-auto max-w-5xl text-center">
      <h2 class="font-display text-4xl font-extrabold text-white sm:text-5xl">
        Why We're Different
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-white/60">
        While others rely on shortcuts that fall flat, we grow your brand
        authentically — exceptionally, but with intention.
      </p>

      <div class="mt-14 grid gap-6 text-left md:grid-cols-2">
        <!-- Others -->
        <div class="rounded-3xl bg-white/[0.04] p-8 ring-1 ring-white/5">
          <h3 class="text-center text-xl font-bold text-white/80">Others</h3>
          <ul class="mt-6 space-y-4">
            {
              othersList.map((item) => (
                <li class="flex items-center gap-3 text-white/60">
                  <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-rose-500/15 text-rose-400">
                    <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
                      <path d="M6 6l12 12M18 6L6 18" />
                    </svg>
                  </span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Synchro Social -->
        <div class="bg-brand-gradient rounded-3xl p-8 shadow-2xl shadow-brand-700/40">
          <h3 class="text-center text-xl font-bold text-white">Synchro Social</h3>
          <ul class="mt-6 space-y-4">
            {
              usList.map((item) => (
                <li class="flex items-center gap-3 font-medium text-white">
                  <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-white/20 text-white">
                    <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12l4 4 10-10" />
                    </svg>
                  </span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="mt-14 flex flex-col items-center gap-3">
        <ApplyButton href="/apply" label="Apply Now" class="w-full max-w-sm" />
        <p class="text-sm text-white/50">
          Get Started In Less Than 60 Seconds • Speak To Our Team Today
        </p>
      </div>

      <!-- Community face wall ⟨PLACEHOLDER⟩ — swap for real audience photos -->
      <div class="mt-20 flex flex-wrap justify-center gap-3 opacity-70 [mask-image:radial-gradient(ellipse_at_center,black_55%,transparent_85%)]">
        {
          Array.from({ length: 30 }).map((_, i) => (
            <div class={`h-12 w-12 rounded-xl bg-gradient-to-br ${["from-brand-400 to-brand-700", "from-violet-400 to-fuchsia-700", "from-indigo-400 to-brand-600", "from-purple-400 to-indigo-700"][i % 4]}`} />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section id="faq" class="bg-brand-tint px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <div class="text-center">
        <h2 class="font-display text-4xl font-extrabold text-ink sm:text-5xl">
          Your Questions, Answered.
        </h2>
        <p class="mt-4 text-muted">
          We know you might have questions — here are clear, straightforward answers.
        </p>
      </div>

      <div class="mt-12 space-y-4">
        {
          faqs.map((f) => (
            <details class="group rounded-2xl bg-white px-6 py-5 shadow-sm ring-1 ring-black/5">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-bold text-ink [&::-webkit-details-marker]:hidden">
                {f.q}
                <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0 text-brand-500 transition group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </summary>
              <p class="mt-4 leading-relaxed text-muted">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== FOOTER ===================== -->
  <footer class="bg-[#06040d] px-6 pt-16 pb-10 text-white">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-5">
        <div class="lg:col-span-2">
          <img src="/images/logo.png" alt="Synchro Social" class="h-14 w-auto" />
          <p class="mt-4 max-w-xs text-sm text-white/50">
            Helping impact-driven coaches &amp; thought leaders share their
            journey on social media.
          </p>
        </div>

        {
          footerCols.map((col) => (
            <div>
              <h4 class="text-xs font-bold uppercase tracking-wider text-white/40">
                {col.title}
              </h4>
              <ul class="mt-4 space-y-3 text-sm text-white/70">
                {col.items.map((it) => (
                  <li>
                    <a href={it.href} class="transition hover:text-white">
                      {it.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <p class="mt-12 text-[0.7rem] leading-relaxed text-white/30">
        NOT FACEBOOK: This site is not a part of the Facebook website or Facebook
        Inc. Additionally, this site is NOT endorsed by Facebook in any way.
        FACEBOOK is a trademark of FACEBOOK, Inc.
      </p>

      <div class="mt-6 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-6 sm:flex-row">
        <p class="text-xs text-white/40">
          © {new Date().getFullYear()} Synchro Social LLC. All rights reserved.
        </p>
        <a href="#" aria-label="Instagram" class="text-white/50 transition hover:text-white">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
      </div>
    </div>
  </footer>
</Layout>
